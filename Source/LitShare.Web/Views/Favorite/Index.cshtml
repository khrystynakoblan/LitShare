@model LitShare.Web.Models.FavoriteViewModel
@{
    ViewData["Title"] = "Вподобані книги";
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4 text-center">@ViewData["Title"]</h2>

    @if (!Model.Favorites.Any())
    {
        <div class="card shadow-sm border-0 text-center py-5 mt-5">
            <div class="card-body">
                <i class="bi bi-heart text-muted display-1"></i>
                <h4 class="text-muted mt-3">У вас ще немає вподобаних книг</h4>
                <p class="text-secondary">Зберігайте книги, які вам сподобалися, щоб не загубити їх</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-dark mt-2 px-4">
                    Перейти до каталогу
                </a>
            </div>
        </div>
    }
    else
    {
        <p class="text-muted text-center mb-5">У вашому списку: <strong>@Model.TotalCount</strong> книг</p>

        <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-4 mb-5">
            @foreach (var book in Model.Favorites)
            {
                <div class="col">
                    <div class="card h-100 p-2 position-relative shadow-sm border-0 card-hover">

                        <form asp-controller="Favorite" asp-action="Toggle" method="post"
                              class="position-absolute top-0 end-0 m-2" style="z-index: 10;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="postId" value="@book.PostId" />
                            <input type="hidden" name="returnUrl" value="/Favorite/Index" />
                            <button type="submit" class="btn btn-light btn-sm rounded-circle shadow-sm p-1" 
                                    title="Видалити з вподобаних" style="width: 32px; height: 32px;">
                                <i class="bi bi-heart-fill text-danger"></i>
                            </button>
                        </form>

                        <a asp-controller="Post" asp-action="Details" asp-route-id="@book.PostId"
                           class="text-decoration-none text-dark h-100 d-flex flex-column">
                            
                            <div class="bg-light rounded overflow-hidden shadow-inner" style="aspect-ratio: 3/4;">
                                @if (!string.IsNullOrEmpty(book.PhotoUrl))
                                {
                                    <img src="@book.PhotoUrl" class="w-100 h-100 object-fit-cover transition-img" alt="@book.Title" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                                        <i class="bi bi-book text-muted display-6"></i>
                                    </div>
                                }
                            </div>

                            <div class="card-body px-1 py-3 text-center mt-auto">
                                <h6 class="mb-1 fw-bold text-truncate" title="@book.Title">@book.Title</h6>
                                <p class="mb-1 text-muted small text-truncate">@book.Author</p>
                                @if (!string.IsNullOrEmpty(book.City))
                                {
                                    <p class="mb-0 text-secondary" style="font-size: 0.75rem;">
                                        <i class="bi bi-geo-alt me-1"></i>@book.City
                                    </p>
                                }
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>