@model LitShare.Web.Models.FavoriteViewModel

@{
    ViewData["Title"] = "Вподобані книги";
}

<div class="container mt-5">

    <h3 class="fw-bold text-center mb-5">
        Вподобані книги
    </h3>

    @if (Model?.Favorites == null || !Model.Favorites.Any())
    {
        <div class="text-center py-5">

            <i class="bi bi-heart text-muted fs-1"></i>

            <p class="text-muted mt-3">
                У вас ще немає вподобаних книг
            </p>

            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-outline-dark mt-2">
                Переглянути книги
            </a>

        </div>
    }
    else
    {
        <p class="text-muted text-center mb-4">
            Знайдено: @(Model.TotalCount)
        </p>

        <div class="row row-cols-2 row-cols-md-4 g-4">

            @foreach (var book in Model.Favorites)
            {
                <div class="col">

                    <div class="card h-100 shadow-sm position-relative">

                        <form asp-controller="Favorite"
                              asp-action="Toggle"
                              method="post"
                              class="position-absolute top-0 end-0 m-2">

                            @Html.AntiForgeryToken()

                            <input type="hidden" name="postId" value="@book.PostId" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                            <button type="submit" class="btn btn-light btn-sm rounded-circle">
                                <i class="bi bi-heart-fill text-danger"></i>
                            </button>

                        </form>

                        <a asp-controller="Post"
                           asp-action="Details"
                           asp-route-id="@book.PostId"
                           class="text-decoration-none text-dark">

                            <div class="bg-light d-flex align-items-center justify-content-center overflow-hidden"
                                 style="aspect-ratio:3/4;">

                                @if (!string.IsNullOrEmpty(book.PhotoUrl))
                                {
                                    <img src="@book.PhotoUrl"
                                         class="w-100 h-100"
                                         alt="@book.Title"
                                         style="object-fit:cover;" />
                                }
                                else
                                {
                                    <i class="bi bi-book fs-1 text-muted"></i>
                                }

                            </div>

                            <div class="p-2 text-center">

                                <p class="mb-0 fw-bold text-truncate"
                                   title="@book.Title">
                                    @book.Title
                                </p>

                                <p class="mb-0 text-muted small">
                                    @book.Author
                                </p>

                                @if (!string.IsNullOrEmpty(book.City))
                                {
                                    <p class="mb-0 text-muted small">
                                        <i class="bi bi-geo-alt"></i>
                                        @book.City
                                    </p>
                                }

                            </div>

                        </a>

                    </div>

                </div>
            }

        </div>
    }

</div>