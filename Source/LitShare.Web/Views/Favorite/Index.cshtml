@model LitShare.Web.Models.FavoriteViewModel
@{
    ViewData["Title"] = "Вподобані книги";
}

<div class="container mt-5">
    <h3 class="fw-bold mb-5 text-center">Вподобані книги</h3>

    @if (!Model.Favorites.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-heart text-muted" style="font-size: 3rem;"></i>
            <p class="text-muted mt-3">У вас ще немає вподобаних книг.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-dark mt-2">Переглянути книги</a>
        </div>
    }
    else
    {
        <p class="text-muted text-center mb-4">Знайдено: @Model.TotalCount книг</p>

        <div class="row row-cols-2 row-cols-md-5 g-4">
            @foreach (var book in Model.Favorites)
            {
                <div class="col text-center">
                    <div class="card h-100 border shadow-sm p-2 bg-white position-relative">

                        <form asp-controller="Favorite" asp-action="Toggle" method="post"
                              class="position-absolute top-0 end-0 m-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="postId" value="@book.PostId" />
                            <input type="hidden" name="returnUrl" value="/Favorite/Index" />
                            <button type="submit" class="btn btn-link p-0 border-0" title="Видалити з вподобаних">
                                <i class="bi bi-heart-fill text-danger" style="font-size: 1.2rem;"></i>
                            </button>
                        </form>

                        <a asp-controller="Post" asp-action="Details" asp-route-id="@book.PostId"
                           class="text-decoration-none text-dark">
                            <div class="bg-light rounded d-flex align-items-center justify-content-center overflow-hidden"
                                 style="aspect-ratio: 3/4;">
                                @if (!string.IsNullOrEmpty(book.PhotoUrl))
                                {
                                    <img src="@book.PhotoUrl" class="w-100 h-100"
                                         style="object-fit: cover;" alt="@book.Title" />
                                }
                                else
                                {
                                    <i class="bi bi-book text-muted fs-1"></i>
                                }
                            </div>
                            <div class="card-body px-0 py-2">
                                <p class="mb-0 fw-bold small text-truncate" title="@book.Title">@book.Title</p>
                                <p class="mb-0 text-muted" style="font-size: 0.75rem;">@book.Author</p>
                                @if (!string.IsNullOrEmpty(book.City))
                                {
                                    <p class="mb-0 text-muted" style="font-size: 0.75rem;">
                                        <i class="bi bi-geo-alt"></i> @book.City
                                    </p>
                                }
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
