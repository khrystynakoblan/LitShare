@model LitShare.Web.Models.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація";
    ViewData["HideHeader"] = true;
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">

        <div class="card p-4 shadow-sm">

            <h2 class="mb-4 text-center">@ViewData["Title"]</h2>

            @{
                var globalErrors = ViewData.ModelState[string.Empty]?.Errors;
            }

            @if (globalErrors != null && globalErrors.Count > 0)
            {
                <div class="alert alert-danger">
                    @foreach (var error in globalErrors)
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-controller="Account" asp-action="Register" method="post" novalidate>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" placeholder="Введіть ім'я" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" placeholder="Електронна пошта" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label fw-semibold"></label>
                    <input asp-for="Phone" class="form-control" placeholder="+380XXXXXXXXX" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <input asp-for="Password" class="form-control" placeholder="Пароль (мін. 8 символів)" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Повторіть пароль" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Region" class="form-label"></label>
                    <input asp-for="Region" class="form-control" placeholder="Область" />
                    <span asp-validation-for="Region" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="District" class="form-label"></label>
                    <input asp-for="District" class="form-control" placeholder="Район" />
                    <span asp-validation-for="District" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" placeholder="Місто" />
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        Зареєструватися
                    </button>
                </div>

                <div class="mt-3 text-center">
                    <span class="text-muted">Вже є акаунт?</span>
                    <a asp-controller="Account" asp-action="Login" class="ms-1">
                        Увійти
                    </a>
                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}