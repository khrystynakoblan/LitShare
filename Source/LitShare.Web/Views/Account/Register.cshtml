@model LitShare.Web.Models.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація";
    ViewData["HideHeader"] = true; 
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">

        <h2 class="mb-4 text-center">@ViewData["Title"]</h2>

        @{
            var globalErrors = ViewData.ModelState[string.Empty]?.Errors;
        }
        @if (globalErrors != null && globalErrors.Count > 0)
        {
            <div class="alert alert-danger" role="alert">
                @foreach (var error in globalErrors)
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="Account" asp-action="Register" method="post" novalidate>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" placeholder="Введіть ваше ім'я" autocomplete="name" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" placeholder="example@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label fw-semibold"></label>
                <input asp-for="Phone" class="form-control" placeholder="+380XXXXXXXXX" autocomplete="tel" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold"></label>
                <input asp-for="Password" class="form-control" placeholder="Мінімум 8 символів" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Повторіть пароль" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Region" class="form-label"></label>
                <input asp-for="Region" class="form-control" placeholder="Наприклад: Львівська" />
                <span asp-validation-for="Region" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="District" class="form-label"></label>
                <input asp-for="District" class="form-control" placeholder="Наприклад: Личаківський" />
                <span asp-validation-for="District" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="City" class="form-label"></label>
                <input asp-for="City" class="form-control" placeholder="Наприклад: Львів" />
                <span asp-validation-for="City" class="text-danger small"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-dark btn-lg">Зареєструватися</button>
            </div>

            <div class="mt-3 text-center">
                <span class="text-muted">Вже є акаунт?</span>
                <a asp-controller="Account" asp-action="Login" class="ms-1">Увійти</a>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
