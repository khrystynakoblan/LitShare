@model LitShare.Web.Models.AdminStatsViewModel

@{
    ViewData["Title"] = "Статистика";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="mb-0">Статистика</h2>

        <a asp-action="Index" class="btn btn-outline-dark">
            ← Назад до скарг
        </a>

    </div>

    @if (Model.Stats == null)
    {
        <div class="alert alert-warning">
            Не вдалося завантажити статистику
        </div>
    }
    else
    {

        <div class="row g-4 mb-4">

            <div class="col-md-3">
                <div class="card p-3 shadow-sm text-center">
                    <div class="text-muted small">Користувачі</div>
                    <h3 class="fw-bold mb-0">@Model.Stats.TotalUsers</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 shadow-sm text-center">
                    <div class="text-muted small">Оголошення</div>
                    <h3 class="fw-bold mb-0">@Model.Stats.TotalPosts</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 shadow-sm text-center">
                    <div class="text-muted small">Активні</div>
                    <h3 class="fw-bold mb-0">@Model.Stats.ActivePosts</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 shadow-sm text-center">
                    <div class="text-muted small">Скарги</div>
                    <h3 class="fw-bold mb-0">@Model.Stats.TotalComplaints</h3>
                </div>
            </div>

        </div>

        <div class="row g-4">

            <div class="col-md-6">
                <div class="card p-3 shadow-sm h-100">

                    <h5 class="mb-3">Топ міст</h5>

                    @if (Model.Stats.TopCities == null || !Model.Stats.TopCities.Any())
                    {
                        <p class="text-muted mb-0">Немає даних</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var city in Model.Stats.TopCities)
                            {
                                <li class="list-group-item d-flex justify-content-between px-0">
                                    <span>@city.City</span>
                                    <span class="badge bg-dark">@city.Count</span>
                                </li>
                            }
                        </ul>
                    }

                </div>
            </div>

            <div class="col-md-6">
                <div class="card p-3 shadow-sm h-100">

                    <h5 class="mb-3">Популярні жанри</h5>

                    @if (Model.Stats.TopGenres == null || !Model.Stats.TopGenres.Any())
                    {
                        <p class="text-muted mb-0">Немає даних</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var genre in Model.Stats.TopGenres)
                            {
                                <li class="list-group-item d-flex justify-content-between px-0">
                                    <span>@genre.GenreName</span>
                                    <span class="badge bg-dark">@genre.Count</span>
                                </li>
                            }
                        </ul>
                    }

                </div>
            </div>

        </div>
    }

</div>