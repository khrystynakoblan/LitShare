@model LitShare.Web.Models.ProfileViewModel

@{
    ViewData["Title"] = "Профіль адміністратора";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="mb-0">Кабінет модератора</h2>

        <div class="d-flex gap-2">

            <a asp-action="Users" class="btn btn-outline-dark">
                Користувачі
            </a>

            <a asp-action="Statistics" class="btn btn-outline-dark">
                Статистика
            </a>

            <a asp-action="Index" class="btn btn-primary">
                Скарги
            </a>

        </div>

    </div>

    <div class="row g-4 align-items-stretch">

        <div class="col-md-4">

            <div class="card p-4 shadow-sm text-center h-100">

                <span class="badge bg-dark mb-3 px-3 py-2">
                    Адміністратор
                </span>

                <img src="@(string.IsNullOrEmpty(Model.PhotoUrl)
                    ? "https://cdn-icons-png.flaticon.com/512/149/149071.png"
                    : Model.PhotoUrl)"
                     class="rounded-circle mx-auto mb-3"
                     style="width:140px;height:140px;object-fit:cover;" />

                <h5 class="fw-bold mb-3">@Model.Name</h5>

                <div class="mt-auto">
                    <a asp-controller="Profile"
                       asp-action="EditProfile"
                       class="btn btn-primary w-100">
                        Оновити профіль
                    </a>
                </div>

            </div>

        </div>

        <div class="col-md-8">

            <div class="card p-4 shadow-sm h-100">

                <h5 class="mb-4">Контактна інформація</h5>

                <div class="mb-3">
                    <p class="text-muted small mb-1">Email</p>
                    <p class="fw-bold">@Model.Email</p>
                </div>

                <div class="mb-3">
                    <p class="text-muted small mb-1">Телефон</p>
                    <p class="fw-bold">
                        @(string.IsNullOrEmpty(Model.Phone) ? "Не вказано" : Model.Phone)
                    </p>
                </div>

                <div class="mb-3">
                    <p class="text-muted small mb-1">ID</p>
                    <p class="fw-bold text-primary">#@Model.UserId</p>
                </div>

                <hr />

                <div>
                    <p class="text-muted small mb-1">Опис</p>
                    <p class="fw-bold text-secondary">
                        @(string.IsNullOrEmpty(Model.About) ? "Опис відсутній" : Model.About)
                    </p>
                </div>

            </div>

        </div>

    </div>

</div>