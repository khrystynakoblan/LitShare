@model LitShare.Web.Models.ProfileViewModel
@{
    ViewData["Title"] = "Профіль Адміністратора";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Кабінет Модератора</h2>
        <div>
            <a asp-action="Statistics" class="btn btn-outline-secondary me-2">Статистика</a>
            <a asp-action="Index" class="btn btn-dark">Скарги</a>
        </div>
    </div>

    <div class="row g-4 align-items-stretch">

        <div class="col-md-4">
            <div class="border rounded p-4 text-center bg-light border-primary border-2 shadow-sm h-100 d-flex flex-column">

                <div class="mb-3">
                    <span class="badge bg-primary px-3 py-2">Адміністратор</span>
                </div>

                <img src="@(string.IsNullOrEmpty(Model.PhotoUrl) ? "https://cdn-icons-png.flaticon.com/512/149/149071.png" : Model.PhotoUrl)"
                     alt="Фото профілю" class="rounded-circle mb-3 mx-auto shadow-sm" style="width:140px; height:140px; object-fit:cover;" />

                <h5 class="fw-bold mb-4">@Model.Name</h5>

                <div class="mt-auto d-grid gap-2">
                    <a asp-controller="Profile" asp-action="EditProfile" class="btn btn-dark">Оновити контакти</a>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="border rounded p-4 shadow-sm h-100 d-flex flex-column">
                <h5 class="fw-bold mb-4"><i class="bi bi-shield-lock me-2"></i>Системні контакти</h5>

                <div class="mb-3">
                    <p class="mb-1 text-muted small">Email для зв'язку</p>
                    <p class="fw-bold fs-6 mb-0">@Model.Email</p>
                </div>

                <div class="mb-3">
                    <p class="mb-1 text-muted small">Телефон</p>
                    <p class="fw-bold fs-6 mb-0">@(string.IsNullOrEmpty(Model.Phone) ? "Не вказано" : Model.Phone)</p>
                </div>

                <div class="row mb-2">
                    <div class="col-12">
                        <p class="mb-1 text-muted small">ID модератора</p>
                        <p class="fw-bold font-monospace text-primary mb-0">#@Model.UserId</p>
                    </div>
                </div>

                <hr class="mt-auto" />

                <div class="w-100">
                    <p class="mb-1 text-muted small">Опис</p>
                    <p class="fw-bold text-secondary mb-0">@Model.About</p>
                </div>
            </div>
        </div>
    </div>
</div>