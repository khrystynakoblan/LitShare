@model LitShare.Web.Models.ComplaintDetailsViewModel

@{
    ViewData["Title"] = "Деталі скарги";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Скаргa #@Model.Complaint!.Id</h2>
        <a asp-action="Index" class="btn btn-outline-dark">
            <i class="bi bi-arrow-left me-1"></i> Назад до списку
        </a>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 text-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>Текст скарги:
                    </h5>
                    <p class="card-text fs-5">@Model.Complaint.Text</p>
                    <div class="mt-3 pt-3 border-top text-muted small">
                        <span><i class="bi bi-person-fill me-1"></i> Від: <strong>@Model.Complaint.ComplainantName</strong></span>
                        <span class="ms-3"><i class="bi bi-calendar-event me-1"></i> Дата: @Model.Complaint.Date.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold py-3">
                    Об'єкт скарги (Оголошення книги)
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        @if (!string.IsNullOrEmpty(Model.Complaint.BookPhotoUrl))
                        {
                            <div class="col-md-3 text-center mb-3 mb-md-0">
                                <img src="@Model.Complaint.BookPhotoUrl" 
                                     alt="Book cover" 
                                     class="img-fluid rounded shadow-sm" 
                                     style="max-height: 250px; object-fit: contain;" />
                            </div>
                        }

                        <div class="@(string.IsNullOrEmpty(Model.Complaint.BookPhotoUrl) ? "col-12" : "col-md-9")">
                            <h3 class="fw-bold mb-2">@Model.Complaint.BookTitle</h3>
                            <p class="text-muted fs-5 mb-3">Автор: @Model.Complaint.BookAuthor</p>
                            <hr />
                            <h6 class="fw-bold">Опис книги в оголошенні:</h6>
                            <p class="mb-0 text-dark p-3 bg-light rounded" style="white-space: pre-line;">@Model.Complaint.BookDescription</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 mt-4 mb-5">
        <form asp-action="Approve" asp-route-id="@Model.Complaint!.Id" method="post" id="approveForm">
            <button type="button" class="btn btn-danger btn-lg px-4" onclick="confirmApprove()">
                <i class="bi bi-check-lg me-2"></i>Підтвердити (Видалити)
            </button>
        </form>

        <form asp-action="Reject" asp-route-id="@Model.Complaint.Id" method="post" id="rejectForm">
            <button type="button" class="btn btn-outline-danger btn-lg px-4" onclick="confirmReject()">
                <i class="bi bi-x-lg me-2"></i>Відхилити скаргу
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/complaints.js" asp-append-version="true"></script>
}