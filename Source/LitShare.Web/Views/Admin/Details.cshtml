@model LitShare.Web.Models.ComplaintDetailsViewModel
@{
    ViewData["Title"] = "Розгляд скарги";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Розгляд скарги</h4>
        <a asp-action="Index" class="btn btn-outline-secondary">← Назад до списку</a>
    </div>

    <div class="border p-4">
        <div class="mb-3">
            <span class="fw-semibold">Скарга:</span>
            <span class="ms-2">@Model.Complaint.Text</span>
        </div>
        <div class="mb-3">
            <span class="fw-semibold">Від:</span>
            <span class="ms-2">@Model.Complaint.ComplainantName</span>
        </div>
        <div class="mb-4">
            <span class="fw-semibold">Дата:</span>
            <span class="ms-2">@Model.Complaint.Date.ToString("dd/MM/yyyy")</span>
        </div>

        <hr />

        <div class="mb-2">
            <span class="fw-semibold">Назва:</span>
            <span class="ms-2">@Model.Complaint.BookTitle</span>
        </div>
        <div class="mb-3">
            <span class="fw-semibold">Автор:</span>
            <span class="ms-2">@Model.Complaint.BookAuthor</span>
        </div>

        <div class="d-flex gap-4 mb-4">
            <div style="width: 200px; height: 200px; flex-shrink: 0;"
                 class="bg-light d-flex align-items-center justify-content-center border">
                @if (!string.IsNullOrEmpty(Model.Complaint.BookPhotoUrl))
                {
                    <img src="@Model.Complaint.BookPhotoUrl" alt="@Model.Complaint.BookTitle"
                         style="width: 100%; height: 100%; object-fit: cover;" />
                }
                else
                {
                    <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                }
            </div>

            <div>
                <p class="fw-semibold mb-1">Опис:</p>
                <p class="text-muted">
                    @(string.IsNullOrEmpty(Model.Complaint.BookDescription) ? "Опис відсутній." : Model.Complaint.BookDescription)
                </p>
            </div>
        </div>

        <div class="d-flex justify-content-between mt-3">
            <form asp-action="Approve" asp-route-id="@Model.Complaint.Id" method="post">
                <button type="submit" class="btn btn-dark"
                        onclick="return confirm('Підтвердити скаргу? Оголошення буде видалено.')">
                    Видалити оголошення
                </button>
            </form>

            <form asp-action="Reject" asp-route-id="@Model.Complaint.Id" method="post">
                <button type="submit" class="btn btn-dark"
                        onclick="return confirm('Відхилити скаргу?')">
                    Відхилити скаргу
                </button>
            </form>
        </div>
    </div>
</div>
