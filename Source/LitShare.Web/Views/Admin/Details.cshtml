@model LitShare.Web.Models.ComplaintDetailsViewModel

@{
    ViewData["Title"] = "Деталі скарги";
}

@if (Model.Complaint == null)
{
    <div class="container mt-4">
        <div class="alert alert-warning">
            Скаргу не знайдено
        </div>
        <a asp-action="Index" class="btn btn-secondary">Назад</a>
    </div>
    return;
}

<div class="container mt-4">

    <h2 class="mb-3">Деталі скарги #@Model.Complaint.Id</h2>

    <div class="card mb-4 p-3 shadow-sm">
        <h5 class="mb-2">Текст скарги</h5>

        <p class="mb-2">@Model.Complaint.Text</p>

        <p class="text-muted small">
            Від: <strong>@Model.Complaint.ComplainantName</strong> |
            @Model.Complaint.Date.ToString("dd.MM.yyyy HH:mm")
        </p>
    </div>

    <div class="card mb-4 p-3 shadow-sm">

        <h5 class="mb-3">Оголошення</h5>

        <div class="row">

            @if (!string.IsNullOrEmpty(Model.Complaint.BookPhotoUrl))
            {
                <div class="col-md-3 text-center mb-3">
                    <img src="@Model.Complaint.BookPhotoUrl"
                         class="img-fluid rounded"
                         alt="Book cover" />
                </div>
            }

            <div class="col-md-9">

                <h4>@Model.Complaint.BookTitle</h4>

                <p><strong>Автор:</strong> @Model.Complaint.BookAuthor</p>

                <hr />

                <p style="white-space: pre-line;">
                    @Model.Complaint.BookDescription
                </p>

            </div>

        </div>

    </div>

    <div class="d-flex gap-2 mb-5">

        <form asp-action="Approve"
              asp-route-id="@Model.Complaint.Id"
              method="post"
              id="approveForm">

            <button type="button"
                    class="btn btn-primary js-approve-btn">
                Підтвердити
            </button>

        </form>

        <form asp-action="Reject"
              asp-route-id="@Model.Complaint.Id"
              method="post"
              id="rejectForm">

            <button type="button"
                    class="btn btn-outline-dark js-reject-btn">
                Відхилити
            </button>

        </form>

        <a asp-action="Index" class="btn btn-secondary">
            Назад
        </a>

    </div>

</div>

@section Scripts {
    <script src="~/js/complaints.js" asp-append-version="true"></script>
}