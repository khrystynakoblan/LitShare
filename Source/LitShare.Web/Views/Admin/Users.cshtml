@model IEnumerable<LitShare.BLL.DTOs.AdminUserListDto>

@{
    ViewData["Title"] = "Користувачі";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Користувачі системи</h2>
        <div class="text-muted">Всього зареєстровано: @Model.Count()</div>
    </div>

    <div class="card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table admin-table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Ім'я</th>
                        <th>Email / Телефон</th>
                        <th>Локація</th>
                        <th>Роль</th>
                        <th class="text-end pe-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@user.Id</td>
                            <td>
                                <div class="fw-bold text-dark">
                                    @user.Name
                                    @if (user.IsBlocked)
                                    {
                                        <span class="badge badge-admin ms-2">Заблоковано</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="small">@user.Email</div>
                                <div class="text-muted small">@user.Phone</div>
                            </td>
                            <td>@user.Location</td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge badge-admin">Адмін</span>
                                }
                                else
                                {
                                    <span class="badge badge-user">Користувач</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    @if (user.Role != "Admin")
                                    {
                                        <form asp-controller="Admin" asp-action="ToggleBlockUser" asp-route-id="@user.Id" method="post">
                                            @if (user.IsBlocked)
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-dark">Розблокувати</button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-dark">Заблокувати</button>
                                            }
                                        </form>
                                    }

                                    <a asp-controller="Profile"
                                       asp-action="GuestProfile"
                                       asp-route-id="@user.Id"
                                       class="btn btn-sm btn-dark">
                                        Профіль
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>