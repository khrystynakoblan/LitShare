@model IEnumerable<LitShare.BLL.DTOs.AdminUserListDto>

@{
    ViewData["Title"] = "Користувачі";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Користувачі системи</h2>
        <div class="text-muted">Всього зареєстровано: @Model.Count()</div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Ім'я</th>
                        <th>Email / Телефон</th>
                        <th>Локація</th>
                        <th>Роль</th>
                        <th class="text-end pe-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@user.Id</td>
                            <td>
                                <div class="fw-bold">@user.Name</div>
                            </td>
                            <td>
                                <div class="small">@user.Email</div>
                                <div class="text-muted small">@user.Phone</div>
                            </td>
                            <td>@user.Location</td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge rounded-pill bg-danger px-3">Адмін</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-info text-dark px-3">Користувач</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                @if (user.Role != "Admin")
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger px-3"
                                            onclick="alert('Функція блокування буде доступна незабаром')">
                                        Заблокувати
                                    </button>
                                }
                                <a asp-controller="Profile"
                                       asp-action="GuestProfile"
                                       asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-primary px-3">
                                    Профіль
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>