@model IEnumerable<LitShare.BLL.DTOs.AdminUserListDto>

@{
    ViewData["Title"] = "Користувачі";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="mb-0">Користувачі системи</h2>

        <div class="text-muted">
            Всього: @Model.Count()
        </div>

    </div>

    <div class="card shadow-sm">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Імʼя</th>
                        <th>Контакти</th>
                        <th>Локація</th>
                        <th>Роль</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var user in Model)
                    {
                        <tr>

                            <td class="text-muted">
                                #@user.Id
                            </td>

                            <td>
                                <div class="fw-bold">
                                    @user.Name

                                    @if (user.IsBlocked)
                                    {
                                        <span class="badge bg-dark ms-2">
                                            Заблоковано
                                        </span>
                                    }
                                </div>
                            </td>

                            <td>
                                <div>@user.Email</div>
                                <div class="text-muted small">@user.Phone</div>
                            </td>

                            <td>
                                @user.Location
                            </td>

                            <td>

                                @if (user.Role == "Admin")
                                {
                                    <span class="badge bg-danger">
                                        Адмін
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Користувач
                                    </span>
                                }

                            </td>

                            <td class="text-end">

                                @if (user.Role != "Admin")
                                {
                                    <form asp-controller="Admin"
                                          asp-action="ToggleBlockUser"
                                          asp-route-id="@user.Id"
                                          method="post"
                                          class="d-inline">

                                        @if (user.IsBlocked)
                                        {
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-success">
                                                Розблокувати
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger">
                                                Заблокувати
                                            </button>
                                        }

                                    </form>
                                }

                                <a asp-controller="Profile"
                                   asp-action="GuestProfile"
                                   asp-route-id="@user.Id"
                                   class="btn btn-sm btn-outline-dark">
                                    Профіль
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>