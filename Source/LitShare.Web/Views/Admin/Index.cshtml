@model LitShare.Web.Models.AdminViewModel
@{
    ViewData["Title"] = "Список скарг";
}
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="Statistics" class="btn btn-primary">
                <i class="me-2"></i>Переглянути статистику
            </a>
        }

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0">Список скарг</h4>
            <p class="text-muted mb-0">Всього скарг: @Model.TotalCount</p>
        </div>
    </div>
        <table class="table table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th>Скарга</th>
                    <th>Назва книги</th>
                    <th>Ім'я</th>
                    <th>Дата</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var complaint in Model.Complaints)
                {
                    <tr style="cursor: pointer;"
                        onclick="window.location='@Url.Action("Details", "Admin", new { id = complaint.Id })'">
                        <td>@complaint.Text</td>
                        <td>@complaint.BookTitle</td>
                        <td>@complaint.ComplainantName</td>
                        <td>@complaint.Date.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
</div>
