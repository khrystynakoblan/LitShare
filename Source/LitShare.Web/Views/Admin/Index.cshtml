@model LitShare.Web.Models.AdminViewModel
@{
    ViewData["Title"] = "Список скарг";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Список скарг</h2>
            <p class="text-muted mb-0">Всього скарг: @Model.TotalCount</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2">
                <a asp-controller="Admin" asp-action="Statistics" class="btn btn-dark">
                    Переглянути статистику
                </a>
                <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-dark">
                    Користувачі
                </a>
            </div>
        }
    </div>

    <div class="card p-0 overflow-hidden">
        <table class="table admin-table table-hover mb-0">
            <thead>
                <tr>
                    <th>Скарга</th>
                    <th>Назва книги</th>
                    <th>Ім'я</th>
                    <th>Дата</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var complaint in Model.Complaints)
                {
                    <tr class="cursor-pointer" onclick="window.location='@Url.Action("Details", "Admin", new { id = complaint.Id })'">
                        <td>@complaint.Text</td>
                        <td>@complaint.BookTitle</td>
                        <td>@complaint.ComplainantName</td>
                        <td>@complaint.Date.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>