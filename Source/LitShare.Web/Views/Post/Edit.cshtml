@model LitShare.Web.Models.PostEditViewModel

@{
    ViewData["Title"] = "Редагувати оголошення";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>LitShare</h2>
        <a href="#" class="text-decoration-none text-dark">Мій профіль</a>
    </div>

    <h3 class="text-center mb-4">Редагувати оголошення</h3>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-4 text-center">
                <div class="border p-3 mb-2" style="height: 250px; background-color: #f8f9fa;">
                    @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                    {
                        <img src="@Model.PhotoUrl" class="img-fluid h-100" alt="Book cover" />
                    }
                    else
                    {
                        <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                    }
                </div>
                <button type="button" class="btn btn-dark w-100">Змінити фото</button>
            </div>

            <div class="col-md-8">
                <div class="mb-3 row">
                    <label asp-for="Title" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="Author" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input asp-for="Author" class="form-control" />
                        <span asp-validation-for="Author" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="SelectedGenreId" class="col-sm-3 col-form-label">Жанр:</label>
                    <div class="col-sm-9">
                        <select asp-for="SelectedGenreId" asp-items="Model.Genres" class="form-select">
                            <option value="">Оберіть жанр</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="DealType" class="col-sm-3 col-form-label">Тип угоди:</label>
                    <div class="col-sm-9">
                        <select asp-for="DealType" asp-items="Model.DealTypes" class="form-select"></select>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <h4 class="text-center mb-3">Опис</h4>
            <textarea asp-for="Description" class="form-control" rows="6"></textarea>
        </div>

        <div class="row mt-4">
            <div class="col-6">
                <button type="submit" class="btn btn-dark w-100 py-2">Зберегти</button>
            </div>
            <div class="col-6">
                <a asp-action="Index" asp-controller="Home" class="btn btn-dark w-100 py-2">Відхилити зміни</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}