@model LitShare.Web.Models.PostEditViewModel

@{
    ViewData["Title"] = "Редагувати оголошення";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-normal">Редагувати оголошення</h2>

        <a asp-controller="Profile"
           asp-action="Index"
           class="text-decoration-none text-dark">
            Мій профіль
        </a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">

            <div class="col-md-4 text-center">

                <div class="border mb-2 d-flex align-items-center justify-content-center"
                     style="height: 350px; background:#f8f9fa; overflow:hidden;">

                    @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                    {
                        <img src="@Model.PhotoUrl"
                             class="w-100 h-100"
                             style="object-fit:cover;" />
                    }
                    else
                    {
                        <div class="text-muted">
                            <i class="bi bi-image fs-1"></i>
                        </div>
                    }

                </div>

                <input type="file"
                       asp-for="NewPhoto"
                       id="imageInput"
                       class="d-none"
                       accept="image/*" />

                <button type="button"
                        class="btn btn-dark w-100 py-2"
                        id="selectImageBtn">
                    Змінити фото
                </button>

                <span asp-validation-for="NewPhoto" class="text-danger"></span>

            </div>

            <div class="col-md-8">

                <div class="mb-3 row">

                    <label asp-for="Title" class="col-sm-3 col-form-label">Назва</label>

                    <div class="col-sm-9">

                        <div class="input-group">
                            <input asp-for="Title"
                                   class="form-control"
                                   id="bookTitleInput" />

                            <button type="button"
                                    class="btn btn-outline-primary"
                                    id="autoFillBtn">
                                Автозаповнити
                            </button>
                        </div>

                        <span asp-validation-for="Title" class="text-danger d-block"></span>

                    </div>

                </div>

                <div class="mb-3 row">

                    <label asp-for="Author" class="col-sm-3 col-form-label">Автор</label>

                    <div class="col-sm-9">
                        <input asp-for="Author" class="form-control" />
                        <span asp-validation-for="Author" class="text-danger"></span>
                    </div>

                </div>

                <div class="mb-3 row">

                    <label asp-for="SelectedGenreIds" class="col-sm-3 col-form-label">Жанри</label>

                    <div class="col-sm-9">

                        <select asp-for="SelectedGenreIds"
                                asp-items="Model.Genres"
                                class="form-select js-select2"
                                multiple>
                        </select>

                    </div>

                </div>

                <div class="mb-3 row">

                    <label asp-for="DealType" class="col-sm-3 col-form-label">Тип</label>

                    <div class="col-sm-9">

                        <select asp-for="DealType"
                                asp-items="Model.DealTypes"
                                class="form-select">
                        </select>

                    </div>

                </div>

            </div>

        </div>

        <div class="mt-4">

            <h4 class="text-center mb-3 fw-normal">Опис</h4>

            <textarea asp-for="Description"
                      class="form-control mb-4"
                      rows="8"></textarea>

            <span asp-validation-for="Description" class="text-danger"></span>

        </div>

        <div class="row gx-2 mb-3">

            <div class="col-6">
                <button type="submit" class="btn btn-dark w-100 py-2 fw-bold">
                    Зберегти
                </button>
            </div>

            <div class="col-6">
                <a asp-controller="Profile"
                   asp-action="MyBooks"
                   class="btn btn-outline-dark w-100 py-2">
                    Скасувати
                </a>
            </div>

        </div>

    </form>

    <button type="button"
            class="btn btn-danger w-100 py-2"
            data-bs-toggle="modal"
            data-bs-target="#deleteModal">
        Видалити книгу
    </button>

</div>

<!-- MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Видалення книги</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                Точно хочеш видалити книгу?
            </div>

            <div class="modal-footer">

                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Скасувати
                </button>

                <form asp-controller="Profile"
                      asp-action="DeletePostConfirmed"
                      method="post">

                    <input type="hidden" name="postId" value="@Model.Id" />

                    <button type="submit" class="btn btn-danger">
                        Видалити
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>