@model LitShare.Web.Models.PostEditViewModel
@{
    ViewData["Title"] = "Редагувати оголошення";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">@ViewData["Title"]</h2>
        <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-dark">Мій профіль</a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-4">
                <div id="imagePreviewContainer" class="card d-flex align-items-center justify-content-center mb-3 p-0 overflow-hidden" style="height: 350px; border-style: dashed !important;">
                    @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                    {
                        <img id="imagePreview" src="@Model.PhotoUrl" class="w-100 h-100 object-fit-cover" />
                    }
                    else
                    {
                        <div id="placeholderContent" class="text-center text-muted">
                            <i class="bi bi-image display-1"></i>
                            <p>Змінити фото</p>
                        </div>
                        <img id="imagePreview" src="#" alt="Прев'ю" class="w-100 h-100 object-fit-cover d-none" />
                    }
                </div>

                <input type="file" asp-for="NewPhoto" id="imageInput" class="d-none" accept="image/*" />
                <button type="button" class="btn btn-dark w-100 py-2" onclick="document.getElementById('imageInput').click();">
                    Змінити фото
                </button>
                <span asp-validation-for="NewPhoto" class="text-danger small"></span>
            </div>

            <div class="col-md-8">
                <div class="mb-3 row">
                    <label asp-for="Title" class="col-sm-2 col-form-label">Назва:</label>
                    <div class="col-sm-10">
                        <div class="input-group">
                            <input asp-for="Title" class="form-control" id="bookTitleInput" required />
                            <button class="btn btn-outline-dark" type="button" id="autoFillBtn">
                                <i class="bi bi-magic me-1"></i> Автозаповнити
                            </button>
                        </div>
                        <span asp-validation-for="Title" class="text-danger small d-block"></span>
                        <span id="apiMessage" class="small mt-1 d-none fw-bold"></span>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="Author" class="col-sm-2 col-form-label">Автор:</label>
                    <div class="col-sm-10">
                        <input asp-for="Author" class="form-control" id="Author" required />
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="SelectedGenreIds" class="col-sm-2 col-form-label">Жанри:</label>
                    <div class="col-sm-10">
                        <select asp-for="SelectedGenreIds" asp-items="Model.Genres" class="form-select js-select2" multiple="multiple" required>
                        </select>
                        <span asp-validation-for="SelectedGenreIds" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="DealType" class="col-sm-2 col-form-label">Угода:</label>
                    <div class="col-sm-10">
                        <select asp-for="DealType" asp-items="Model.DealTypes" class="form-select" required></select>
                        <span asp-validation-for="DealType" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <h4 class="fw-bold mb-3">Опис</h4>
            <textarea asp-for="Description" class="form-control mb-4" id="Description" rows="8" required></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <button type="submit" class="btn btn-dark w-100 py-2">Зберегти зміни</button>
            </div>
            <div class="col-md-4">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark w-100 py-2">Скасувати</a>
            </div>
            <div class="col-md-4">
                <button type="button" class="btn btn-outline-danger w-100 py-2" data-bs-toggle="modal" data-bs-target="#deleteModal">
                    Видалити книгу
                </button>
            </div>
        </div>
    </form>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Підтвердження видалення</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Ви впевнені, що хочете видалити цю книгу? Цю дію неможливо буде скасувати.
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                <form asp-controller="Post" asp-action="DeleteConfirmed" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger px-4">Так, видалити</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/autofill.js" asp-append-version="true"></script>
    <script src="~/js/create-post.js" asp-append-version="true"></script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}