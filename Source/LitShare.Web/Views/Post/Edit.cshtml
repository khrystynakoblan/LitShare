@model LitShare.Web.Models.PostEditViewModel
@{
    ViewData["Title"] = "Редагувати оголошення";
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-normal">Редагувати оголошення</h2>
        <a asp-controller="Profile" asp-action="Index" class="text-decoration-none text-dark">Мій профіль</a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-4 text-center">
                <div id="imagePreviewContainer" class="border mb-2 d-flex align-items-center justify-content-center"
                     style="height: 350px; background-color: #f8f9fa; overflow: hidden;">
                    @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                    {
                        <img id="imagePreview" src="@Model.PhotoUrl"
                             style="width: 100%; height: 100%; object-fit: cover;" alt="Book cover" />
                    }
                    else
                    {
                        <img id="imagePreview" src="#"
                             style="display: none; width: 100%; height: 100%; object-fit: cover;" alt="Book cover" />
                        <div id="placeholderContent" class="text-muted">
                            <i class="bi bi-image" style="font-size: 4rem;"></i>
                        </div>
                    }
                </div>
                <input type="file" asp-for="NewPhoto" id="imageInput"
                       class="d-none" accept="image/*" />
                <button type="button" class="btn btn-dark w-100"
                        onclick="document.getElementById('imageInput').click();">
                    Змінити фото
                </button>
                <span asp-validation-for="NewPhoto" class="text-danger"></span>
            </div>

            <div class="col-md-8">
                <div class="mb-3 row">
                    <label asp-for="Title" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Author" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input asp-for="Author" class="form-control" />
                        <span asp-validation-for="Author" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="SelectedGenreId" class="col-sm-3 col-form-label">Жанр:</label>
                    <div class="col-sm-9">
                        <select asp-for="SelectedGenreId" asp-items="Model.Genres" class="form-select">
                            <option value="">Оберіть жанр</option>
                        </select>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="DealType" class="col-sm-3 col-form-label">Тип угоди:</label>
                    <div class="col-sm-9">
                        <select asp-for="DealType" asp-items="Model.DealTypes" class="form-select"></select>
                    </div>
                </div>
            </div>

        </div>
        <div class="mt-4">
            <h4 class="text-center mb-3">Опис</h4>
            <textarea asp-for="Description" class="form-control" rows="6"></textarea>
        </div>
        <div class="row mt-4">
            <div class="col-6">
                <button type="submit" class="btn btn-dark w-100 py-2">Зберегти</button>
            </div>
            <div class="col-6">
                <a asp-action="Index" asp-controller="Home" class="btn btn-dark w-100 py-2">Відхилити зміни</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('imageInput').onchange = function () {
            const [file] = this.files;
            if (file) {
                const preview = document.getElementById('imagePreview');
                const placeholder = document.getElementById('placeholderContent');

                preview.src = URL.createObjectURL(file);
                preview.style.display = 'block';

                if (placeholder) {
                    placeholder.style.display = 'none';
                }
            }
        };
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}