@model LitShare.BLL.DTOs.PostDetailsDto

<div class="container mt-5 text-center">
    <h3 class="mb-4">Ви впевнені, що хочете видалити цю книгу?</h3>

    <div class="card p-4 mx-auto" style="max-width: 400px;">
        <h5>@Model.Title</h5>
        <p class="text-muted">@Model.Author</p>

        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" name="id" value="@Model.Id" />

            <button type="submit" class="btn btn-danger w-100 mb-2">
                Видалити
            </button>
        </form>

        <a asp-controller="Profile" asp-action="MyBooks" class="btn btn-outline-secondary w-100">
            Скасувати
        </a>
    </div>
</div>