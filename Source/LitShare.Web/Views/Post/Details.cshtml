@model LitShare.Web.Models.PostDetailsViewModel
@using System.Security.Claims

@{
    ViewData["Title"] = "Оголошення";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="bg-secondary-subtle d-flex align-items-center justify-content-center"
                 style="height: 400px;">
                @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                {
                    <img src="@Model.PhotoUrl" class="img-fluid h-100 w-100"
                         style="object-fit: cover;" alt="Book cover" />
                }
                else
                {
                    <i class="bi bi-image text-muted" style="font-size: 5rem;"></i>
                }
            </div>
        </div>

        <div class="col-md-8 ps-5">
            <h3 class="fw-bold mb-1">@Model.Title</h3>
            <p class="text-muted mb-3">@Model.Author</p>

            <p>
                <strong>Жанр:</strong>
                @string.Join(", ", Model.Genres)
            </p>

            <p class="fw-bold mb-1">Опис</p>
            <p>@Model.Description</p>

            <p>
                <strong>Тип угоди:</strong>
                @(Model.DealType == LitShare.DAL.Models.DealType.Exchange ? "Обмін" : "Дарування")
            </p>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">

        <a asp-controller="Profile" asp-action="GuestProfile" asp-route-id="@Model.UserId"
               class="btn btn-dark d-flex align-items-center justify-content-center"
               style="width: 240px; height: 50px;">
            Профіль користувача
        </a>

        @if (User.Identity?.IsAuthenticated == true)
        {
            var currentUserIdString = User.FindFirstValue(ClaimTypes.NameIdentifier);
            int.TryParse(currentUserIdString, out int currentUserId);

            @if (currentUserId == Model.UserId)
            {
                <a asp-controller="Post" asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-outline-dark d-flex align-items-center justify-content-center"
                       style="width: 240px; height: 50px;">
                    Редагувати оголошення
                </a>
            }
            else
            {
                <div class="d-flex gap-2">
                    @if (Model.HasAlreadyRequested)
                    {
                        <button class="btn btn-secondary d-flex align-items-center justify-content-center"
                                style="width: 240px; height: 50px;" disabled>
                            Запит надіслано
                        </button>
                    }
                    else
                    {
                        <form asp-controller="Exchange" asp-action="CreateRequest" method="post">
                            <input type="hidden" name="postId" value="@Model.Id" />
                            <button type="submit" class="btn btn-dark d-flex align-items-center justify-content-center"
                                    style="width: 240px; height: 50px;"
                                    onclick="return confirm('Чи дійсно Ви хочете надіслати запит?')">
                                Надіслати запит
                            </button>
                        </form>
                    }

                    <a asp-controller="Complaint" asp-action="Create" asp-route-postId="@Model.Id"
                           class="btn btn-outline-dark d-flex align-items-center justify-content-center"
                           style="width: 240px; height: 50px;">
                        Поскаржитися
                    </a>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            alert('@Html.Raw(TempData["SuccessMessage"])');
        </script>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            alert('@Html.Raw(TempData["ErrorMessage"])');
        </script>
    }
}