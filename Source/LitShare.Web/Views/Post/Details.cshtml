@model LitShare.Web.Models.PostDetailsViewModel
@using System.Security.Claims
@using LitShare.DAL.Models

@{
    ViewData["Title"] = "Оголошення";
}

<div class="container mt-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">

        <div class="col-md-4">

            <div class="card shadow-sm overflow-hidden" style="height: 400px;">

                @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                {
                    <img src="@Model.PhotoUrl"
                         class="w-100 h-100"
                         style="object-fit:cover;" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                        <i class="bi bi-image text-muted fs-1"></i>
                    </div>
                }

            </div>

        </div>

        <div class="col-md-8">

            <h3 class="fw-bold mb-1">@Model.Title</h3>

            <p class="text-muted">@Model.Author</p>

            <p class="mb-2">
                <strong>Жанри:</strong>
                @string.Join(", ", Model.Genres)
            </p>

            <p class="mb-3">
                <strong>Тип угоди:</strong>
                @(Model.DealType == DealType.Exchange ? "Обмін" : "Дарування")
            </p>

            <p class="fw-bold mb-1">Опис</p>

            <p class="text-muted">
                @Model.Description
            </p>

        </div>

    </div>

    <div class="d-flex gap-2 flex-wrap mt-4">

        <!-- PROFILE -->
        <a asp-controller="Profile"
           asp-action="GuestProfile"
           asp-route-id="@Model.UserId"
           class="btn btn-dark">
            Профіль користувача
        </a>

        @if (User.Identity?.IsAuthenticated == true)
        {
            var currentUserIdString = User.FindFirstValue(ClaimTypes.NameIdentifier);
            int.TryParse(currentUserIdString, out int currentUserId);

            @if (currentUserId == Model.UserId)
            {
                <a asp-controller="Post"
                   asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-outline-dark">
                    Редагувати
                </a>
            }
            else
            {
                @if (Model.HasAlreadyRequested)
                {
                    <button class="btn btn-secondary" disabled>
                        Запит надіслано
                    </button>
                }
                else
                {
                    <!-- EXCHANGE -->
                    <form asp-controller="Exchange"
                          asp-action="CreateRequest"
                          method="post">

                        <input type="hidden" name="postId" value="@Model.Id" />

                        <button type="submit" class="btn btn-dark">
                            Надіслати запит
                        </button>

                    </form>

                    <!-- COMPLAINT (FIXED) -->
                    <form asp-controller="Complaint"
                          asp-action="Create"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden" name="PostId" value="@Model.Id" />

                        <button type="submit" class="btn btn-outline-dark">
                            Поскаржитися
                        </button>

                    </form>
                }
            }
        }

    </div>

</div>