@model LitShare.Web.Models.CreatePostModel

@{
    ViewData["Title"] = "Нове оголошення";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-normal">Нове оголошення</h2>

        <a asp-controller="Profile"
           asp-action="Index"
           class="text-decoration-none text-dark">
            Мій профіль
        </a>
    </div>

    <form asp-action="CreatePost"
          method="post"
          enctype="multipart/form-data">

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3"></div>

        <div class="row">

            <!-- IMAGE -->
            <div class="col-md-4 text-center">

                <div class="border rounded bg-light d-flex align-items-center justify-content-center mb-3"
                     style="height: 350px; border-style: dashed; overflow: hidden;"
                     id="imagePreviewContainer">

                    <div class="text-muted" id="placeholderContent">
                        <i class="bi bi-image fs-1"></i>
                        <p>Виберіть фото</p>
                    </div>

                    <img id="imagePreview"
                         class="w-100 h-100"
                         style="display:none; object-fit:cover;" />
                </div>

                <input type="file"
                       asp-for="ImageFile"
                       id="imageInput"
                       class="d-none"
                       accept="image/*" />

                <button type="button"
                        class="btn btn-dark w-100 py-2"
                        id="selectImageBtn">
                    Додати фото
                </button>

                <span asp-validation-for="ImageFile"
                      class="text-danger"></span>

            </div>

            <!-- FIELDS -->
            <div class="col-md-8">

                <div class="mb-3 row">

                    <label asp-for="Title" class="col-sm-2 col-form-label">
                        Назва
                    </label>

                    <div class="col-sm-10">

                        <div class="input-group">

                            <input asp-for="Title"
                                   class="form-control"
                                   id="bookTitleInput" />

                            <button type="button"
                                    class="btn btn-outline-primary"
                                    id="autoFillBtn">
                                Автозаповнити
                            </button>

                        </div>

                        <span asp-validation-for="Title"
                              class="text-danger d-block"></span>

                    </div>

                </div>

                <div class="mb-3 row">

                    <label asp-for="Author" class="col-sm-2 col-form-label">
                        Автор
                    </label>

                    <div class="col-sm-10">

                        <input asp-for="Author"
                               class="form-control" />

                        <span asp-validation-for="Author"
                              class="text-danger"></span>

                    </div>

                </div>

                <!-- GENRES -->
                <div class="mb-3 row">

                    <label asp-for="SelectedGenreIds" class="col-sm-2 col-form-label">
                        Жанри
                    </label>

                    <div class="col-sm-10">

                        <select asp-for="SelectedGenreIds"
                                asp-items="Model.Genres"
                                class="form-select js-select2"
                                multiple>
                        </select>

                    </div>

                </div>

                <!-- DEAL TYPE -->
                <div class="mb-3 row">

                    <label asp-for="DealTypeId" class="col-sm-2 col-form-label">
                        Тип
                    </label>

                    <div class="col-sm-10">

                        <select asp-for="DealTypeId"
                                asp-items="Model.DealTypes"
                                class="form-select">

                            <option value="0">Оберіть тип</option>

                        </select>

                    </div>

                </div>

            </div>
        </div>

        <!-- DESCRIPTION -->
        <div class="row mt-4">

            <div class="col-12 text-center">

                <h4 class="fw-normal mb-3">Опис</h4>

                <textarea asp-for="Description"
                          class="form-control mb-4"
                          rows="8"></textarea>

                <span asp-validation-for="Description"
                      class="text-danger"></span>

            </div>

        </div>

        <!-- BUTTONS -->
        <div class="row mb-5">

            <div class="col-6">
                <button type="submit"
                        class="btn btn-dark w-100 fw-bold">
                    Зберегти
                </button>
            </div>

            <div class="col-6">
                <a asp-action="Index"
                   asp-controller="Home"
                   class="btn btn-outline-dark w-100">
                    Скасувати
                </a>
            </div>

        </div>

    </form>

</div>

@section Scripts {

    <script src="~/js/create-post.js" asp-append-version="true"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}