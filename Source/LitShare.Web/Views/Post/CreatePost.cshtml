@model LitShare.Web.Models.CreatePostModel
@{
    ViewData["Title"] = "Нове оголошення";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">@ViewData["Title"]</h2>
        <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-dark">Мій профіль</a>
    </div>

    <form asp-action="CreatePost" method="post" enctype="multipart/form-data" class="shadow-sm p-4 bg-white rounded-4 border-0">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <div class="col-md-4 text-center">
                <div id="imagePreviewContainer" class="card shadow-inner d-flex align-items-center justify-content-center mb-3 overflow-hidden"
                     style="height: 380px; border: 2px dashed #ddd !important;">
                    <div id="placeholderContent" class="text-muted p-4">
                        <i class="bi bi-cloud-arrow-up display-3"></i>
                        <p class="fw-bold mt-2">Перетягніть або виберіть фото</p>
                    </div>
                    <img id="imagePreview" src="#" alt="Прев'ю" class="w-100 h-100 object-fit-cover d-none" />
                </div>
                <input type="file" asp-for="ImageFile" id="imageInput" class="d-none" accept="image/*" required />
                <button type="button" class="btn btn-dark w-100 py-2" onclick="document.getElementById('imageInput').click();">
                    <i class="bi bi-camera me-2"></i>Додати фото
                </button>
                <span asp-validation-for="ImageFile" class="text-danger small"></span>
            </div>

            <div class="col-md-8">
                <div class="mb-4">
                    <label class="form-label fw-bold small">Назва книги:</label>
                    <div class="input-group">
                        <input asp-for="Title" class="form-control" id="bookTitleInput" placeholder="Наприклад: Маленький принц" required />
                        <button class="btn btn-outline-dark" type="button" id="autoFillBtn">
                            <i class="bi bi-magic me-1"></i> Автозаповнити
                        </button>
                    </div>
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small">Автор:</label>
                    <input asp-for="Author" class="form-control" id="Author" placeholder="Антуан де Сент-Екзюпері" required />
                    <span asp-validation-for="Author" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small">Жанри:</label>
                    <select asp-for="SelectedGenreIds" asp-items="Model.Genres" class="form-select js-select2" multiple="multiple" required>
                    </select>
                    <span asp-validation-for="SelectedGenreIds" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small">Тип угоди:</label>
                    <select asp-for="DealTypeId" asp-items="Model.DealTypes" class="form-select" required>
                        <option value="">Оберіть тип...</option>
                    </select>
                    <span asp-validation-for="DealTypeId" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <h5 class="fw-bold mb-3">Опис</h5>
            <textarea asp-for="Description" class="form-control mb-4 shadow-inner" id="Description" rows="8" placeholder="Розкажіть про стан книги, рік видання або чому ви її віддаєте..." required></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <button type="submit" class="btn btn-dark w-100 py-3 fw-bold">Створити оголошення</button>
            </div>
            <div class="col-md-6">
                <a asp-action="Index" asp-controller="Home" class="btn btn-outline-dark w-100 py-3">Скасувати</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/create-post.js" asp-append-version="true"></script>
    <script src="~/js/autofill.js" asp-append-version="true"></script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}