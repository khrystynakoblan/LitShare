<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LitShare.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LitShare.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @if (ViewData["HideHeader"] as bool? != true)
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 p-3">
                <div class="container-fluid">

                    <a class="navbar-brand fw-bold fs-3 text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                        LitShare
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">

                        <form class="d-flex mx-auto w-50 my-2 my-sm-0" asp-controller="Home" asp-action="Index" method="get">
                            <input class="form-control rounded-1" type="search" name="searchTerm" placeholder="Пошук..." aria-label="Search">
                        </form>

                        <ul class="navbar-nav align-items-center flex-row">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item me-3">
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-link text-dark p-0 border-0" title="Вийти">
                                            <i class="bi bi-box-arrow-right fs-3"></i>
                                        </button>
                                    </form>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark p-0" asp-controller="Profile" asp-action="MyProfile" title="Мій профіль">
                                        <i class="bi bi-person-circle fs-3"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger text-center mb-0">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - LitShare.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
