<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LitShare</title>

    @* Бібліотеки стилів *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    @* Кастомні стилі *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />

    @if (User.IsInRole("Admin"))
    {
        <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    }

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (ViewData["HideHeader"] as bool? != true)
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-4 p-3">
                <div class="container-fluid">
                    <a class="navbar-brand fw-bold text-dark"
                       asp-controller="@(User.IsInRole("Admin") ? "Admin" : "Home")"
                       asp-action="Index">
                        LitShare )
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse">
                        @if (ViewData["ShowSearch"] as bool? == true && !User.IsInRole("Admin"))
                        {
                            <form class="d-flex mx-auto w-50 my-2 my-sm-0" asp-controller="Home" asp-action="Index" method="get">
                                <input class="form-control rounded-pill px-3" type="search" name="searchTerm"
                                       placeholder="Знайти книгу або автора..."
                                       value="@Context.Request.Query["searchTerm"]" />
                                <button class="btn btn-dark rounded-pill ms-2 px-3" type="submit">
                                    <i class="bi bi-search"></i>
                                </button>
                            </form>
                        }

                        <ul class="navbar-nav ms-auto align-items-center flex-row gap-2">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark p-0"
                                       asp-controller="@(User.IsInRole("Admin") ? "Admin" : "Profile")"
                                       asp-action="MyProfile" title="Мій профіль">
                                        <i class="bi bi-person-circle fs-3"></i>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-link text-danger p-0 border-0" title="Вийти">
                                            <i class="bi bi-box-arrow-right fs-3"></i>
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="btn btn-outline-dark btn-sm px-3 rounded-pill" asp-controller="Account" asp-action="Login">Увійти</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    <main role="main" class="container pb-4">
        @RenderBody()
    </main>

    <footer class="footer mt-auto">
        <div class="container text-center">
            <small>&copy; 2026 — <strong>LitShare</strong>. Платформа для обміну книгами</small>
        </div>
    </footer>

    @* Скрипти бібліотек *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @* ВИПРАВЛЕННЯ: SweetAlert сповіщення через TempData *@
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                Swal.fire({
                    icon: 'success',
                    title: 'Успішно!',
                    text: '@Html.Raw(TempData["SuccessMessage"]?.ToString()?.Replace("'", "\\'"))',
                    confirmButtonColor: '#111',
                    timer: 3500,
                    timerProgressBar: true,
                    showConfirmButton: false
                });
            });
        </script>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                Swal.fire({
                    icon: 'error',
                    title: 'Помилка',
                    text: '@Html.Raw(TempData["ErrorMessage"]?.ToString()?.Replace("'", "\\'"))',
                    confirmButtonColor: '#111'
                });
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
