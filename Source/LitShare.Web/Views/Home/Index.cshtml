@model LitShare.Web.Models.HomeViewModel
@{
    ViewData["Title"] = "Головна";
}

<div class="container-fluid mt-3">
    <div class="row">

        <div class="col-md-2">
            <div class="border p-3">
                <h6 class="fw-semibold">Фільтр:</h6>
                @* фільтри будуть тут *@
            </div>
        </div>

        <div class="col-md-10">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">Знайдено: @Model.TotalCount книг</span>
                <a asp-controller="Post" asp-action="CreatePost" class="btn btn-dark">
                    + Додати книгу
                </a>
            </div>

            @if (!Model.Posts.Any())
            {
                <div class="text-center text-muted mt-5">
                    <p>Оголошень ще немає.</p>
                </div>
            }
            else
            {
                <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
                    @foreach (var post in Model.Posts)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                                     style="height: 200px; overflow: hidden;">
                                    @if (!string.IsNullOrEmpty(post.PhotoUrl))
                                    {
                                        <img src="@post.PhotoUrl"
                                             alt="@post.Title"
                                             style="width: 100%; height: 100%; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                                    }
                                </div>

                                <div class="card-body p-2 text-center">
                                    <p class="mb-0 fw-semibold small">@post.Title</p>
                                    <p class="mb-0 text-muted small">@post.Author</p>
                                    <p class="mb-0 text-muted small">@(post.City ?? "—")</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
