@model LitShare.Web.Models.HomeViewModel
@using LitShare.DAL.Models

@{
    ViewData["Title"] = "Головна";
}

<div class="container-fluid mt-3">

    <div class="row">

        <div class="col-md-3">

            <div class="card shadow-sm p-3">

                <h6 class="fw-semibold mb-3">Фільтри</h6>

                <form method="get" asp-action="Index" id="filterForm">

                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                    }

                    <div class="mb-3">
                        <label class="form-label">Локація</label>
                        <input type="text"
                               name="location"
                               class="form-control form-control-sm"
                               value="@Model.Location" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Тип угоди</label>

                        <div class="form-check">
                            <input type="radio"
                                   name="dealType"
                                   value="@((int)DealType.Exchange)"
                                   class="form-check-input"
                                   @(Model.DealType == DealType.Exchange ? "checked" : null) />
                            <label class="form-check-label">Обмін</label>
                        </div>

                        <div class="form-check">
                            <input type="radio"
                                   name="dealType"
                                   value="@((int)DealType.Donation)"
                                   class="form-check-input"
                                   @(Model.DealType == DealType.Donation ? "checked" : null) />
                            <label class="form-check-label">Дарування</label>
                        </div>

                        <div class="form-check">
                            <input type="radio"
                                   name="dealType"
                                   value=""
                                   class="form-check-input"
                                   @(Model.DealType == null ? "checked" : null) />
                            <label class="form-check-label">Всі</label>
                        </div>

                    </div>

                    <div class="mb-3">
                        <label class="form-label">Жанри</label>

                        @if (Model.AllGenres != null)
                        {
                            foreach (var genre in Model.AllGenres)
                            {
                                <div class="form-check">
                                    <input type="checkbox"
                                           name="genres"
                                           value="@genre.Id"
                                           class="form-check-input"
                                           @(Model.SelectedGenres?.Contains(genre.Id) == true ? "checked" : null) />

                                    <label class="form-check-label">
                                        @genre.Name
                                    </label>
                                </div>
                            }
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(Model.SearchTerm)
                        || !string.IsNullOrEmpty(Model.Location)
                        || Model.DealType != null
                        || (Model.SelectedGenres?.Any() == true))
                    {
                        <a asp-action="Index" class="btn btn-outline-dark w-100">
                            Скинути
                        </a>
                    }

                </form>

            </div>

        </div>

        <div class="col-md-9">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">Знайдено: @Model.TotalCount</span>

                <a asp-controller="Post"
                   asp-action="CreatePost"
                   class="btn btn-primary">
                    + Додати
                </a>
            </div>

            @if (Model.Posts == null || !Model.Posts.Any())
            {
                <div class="text-center text-muted mt-5">
                    Нічого не знайдено
                </div>
            }
            else
            {
                <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">

                    @foreach (var post in Model.Posts)
                    {
                        bool isFav = Model.FavoritePostIds?.Contains(post.Id) == true;

                        <div class="col">

                            <div class="card shadow-sm h-100 position-relative">

                                <form asp-controller="Favorite"
                                      asp-action="Toggle"
                                      method="post"
                                      class="position-absolute top-0 end-0 m-2">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="postId" value="@post.Id" />
                                    <input type="hidden" name="returnUrl"
                                           value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />

                                    <button type="submit" class="btn btn-light btn-sm rounded-circle">
                                        <i class="bi @(isFav ? "bi-heart-fill text-danger" : "bi-heart")"></i>
                                    </button>

                                </form>

                                <a asp-controller="Post"
                                   asp-action="Details"
                                   asp-route-id="@post.Id"
                                   class="text-decoration-none text-dark">

                                    <div class="bg-light d-flex align-items-center justify-content-center"
                                         style="aspect-ratio:3/4;">

                                        @if (!string.IsNullOrEmpty(post.PhotoUrl))
                                        {
                                            <img src="@post.PhotoUrl"
                                                 class="w-100 h-100"
                                                 style="object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-image fs-1 text-muted"></i>
                                        }

                                    </div>

                                    <div class="p-2 text-center">
                                        <p class="mb-0 fw-semibold small">@post.Title</p>
                                        <p class="mb-0 text-muted small">@post.Author</p>
                                        <p class="mb-0 text-muted small">@(post.City ?? "—")</p>
                                    </div>

                                </a>

                            </div>

                        </div>
                    }

                </div>
            }

        </div>

    </div>

</div>