@using LitShare.BLL.DTOs
@model LitShare.Web.Models.ProfileViewModel
@{
    ViewData["Title"] = "Мої книги";
}

<div class="container mt-5">
    <h3 class="fw-bold mb-5 text-center">Мої книги</h3>

    <div class="row row-cols-2 row-cols-md-5 g-4">
        @if (Model.UserBooks != null && Model.UserBooks.Any())
        {
            @foreach (var book in Model.UserBooks)
            {
                bool isFavorited = Model.FavoritePostIds.Contains(book.Id);

                <div class="col text-center">
                    <div class="card h-100 border shadow-sm p-2 bg-white position-relative">

                        <form asp-controller="Favorite" asp-action="Toggle" method="post"
                              class="position-absolute top-0 end-0 m-1" style="z-index: 1;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="postId" value="@book.Id" />
                            <input type="hidden" name="returnUrl" value="/Profile/MyBooks" />
                            <button type="submit" class="btn btn-link p-1 border-0"
                                    title="@(isFavorited ? "Видалити з вподобаних" : "Додати до вподобаних")">
                                <i class="bi @(isFavorited ? "bi-heart-fill text-danger" : "bi-heart text-muted")"
                                   style="font-size: 1.2rem;"></i>
                            </button>
                        </form>

                        <div class="bg-light rounded d-flex align-items-center justify-content-center overflow-hidden"
                             style="aspect-ratio: 3/4;">
                            @if (!string.IsNullOrEmpty(book.PhotoUrl))
                            {
                                <img src="@book.PhotoUrl" class="w-100 h-100"
                                     style="object-fit: cover;" alt="@book.Title" />
                            }
                            else
                            {
                                <i class="bi bi-image text-secondary" style="font-size: 2.5rem;"></i>
                            }
                        </div>
                        <div class="card-body px-0 py-2">
                            <p class="mb-0 fw-bold small text-truncate" title="@book.Title">@book.Title</p>
                            <p class="mb-0 text-muted extra-small">@book.Author</p>
                            <p class="mb-2 text-muted extra-small">
                                <i class="bi bi-geo-alt"></i> @(book.City ?? "—")
                            </p>
                            <a asp-controller="Post" asp-action="Edit" asp-route-id="@book.Id"
                               class="btn btn-dark w-100 extra-small py-1"
                               style="border-radius: 4px;">
                                Редагувати
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">У вас ще немає доданих книг.</p>
                <a asp-controller="Post" asp-action="CreatePost" class="btn btn-sm btn-outline-dark">
                    Додати першу книгу
                </a>
            </div>
        }
    </div>
</div>

<style>
    .extra-small {
        font-size: 0.75rem;
    }

    .card {
        border: 1px solid #f0f0f0 !important;
        border-radius: 8px;
    }
</style>
