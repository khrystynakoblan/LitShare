@model LitShare.Web.Models.ProfileViewModel
@{
    ViewData["Title"] = "Редагування профілю";
    var targetController = User.IsInRole("Admin") ? "Admin" : "Profile";
    var targetAction = User.IsInRole("Admin") ? "MyProfile" : "MyProfile";
}

<div class="container mt-4 mb-5">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-controller="@targetController" asp-action="@targetAction"
           class="btn btn-outline-dark btn-sm">
        </a>
        <h2 class="fw-bold mb-0">@ViewData["Title"]</h2>
    </div>

    <div class="row g-4">

        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                <img src="@(string.IsNullOrEmpty(Model.PhotoUrl)
                        ? "https://cdn-icons-png.flaticon.com/512/149/149071.png"
                        : Model.PhotoUrl)"
                     alt="Фото профілю"
                     class="rounded-circle mx-auto mb-3 shadow-sm"
                     style="width:130px; height:130px; object-fit:cover; border: 4px solid #fff;" />

                <p class="fw-bold mb-1">@Model.Name</p>
                <p class="text-muted small mb-3">@Model.Email</p>

                <form asp-controller="Profile" asp-action="GenerateAvatar" method="post">
                    <input type="hidden" asp-for="Name" />
                    <input type="hidden" asp-for="City" />
                    <input type="hidden" asp-for="District" />
                    <input type="hidden" asp-for="Region" />
                    <input type="hidden" asp-for="Phone" />
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="About" />
                    <button type="submit" class="btn btn-outline-dark btn-sm w-100">
                        <i class="bi bi-arrow-repeat me-2"></i>Згенерувати аватар
                    </button>
                </form>
                <p class="text-muted small mt-2 mb-0">Унікальний AI-аватар</p>
            </div>
        </div>

        <div class="col-md-8 col-lg-9">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <form asp-controller="Profile" asp-action="EditProfile" method="post">
                    <input type="hidden" asp-for="PhotoUrl" />
                    <input type="hidden" asp-for="Name" />

                    <h5 class="fw-bold mb-4 pb-2 border-bottom">Основна інформація</h5>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Ім'я</label>
                            <input class="form-control bg-light" value="@Model.Name" readonly />
                            <div class="form-text">Ім'я не можна змінити після реєстрації</div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" asp-for="City">Місто</label>
                            <input class="form-control" asp-for="City" placeholder="Напр. Київ" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" asp-for="District">Район</label>
                            <input class="form-control" asp-for="District" placeholder="Напр. Печерський" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" asp-for="Region">Область</label>
                            <input class="form-control" asp-for="Region" placeholder="Напр. Київська" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" asp-for="Phone">Телефон</label>
                            <input class="form-control" asp-for="Phone" placeholder="+380..." />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold" asp-for="Email">Контактний Email</label>
                            <input class="form-control" asp-for="Email" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold" asp-for="About">Про себе</label>
                            <textarea class="form-control" asp-for="About" rows="4"
                                      placeholder="Розкажіть про свої книги та читацькі інтереси..."></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-dark px-4">
                            <i class="bi bi-check-lg me-1"></i>Зберегти зміни
                        </button>
                        <a asp-controller="@targetController" asp-action="@targetAction"
                           class="btn btn-outline-dark px-4">
                            Скасувати
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
