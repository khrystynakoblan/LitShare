@model LitShare.Web.Models.ProfileViewModel

@{
    ViewData["Title"] = "Редагування профілю";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-10">

            <div class="card shadow-sm p-4">

                <h3 class="fw-bold text-center mb-4">
                    Редагування профілю
                </h3>

                <div class="row g-4">

                    <div class="col-md-4 text-center">

                        <img src="@(string.IsNullOrEmpty(Model.PhotoUrl)
                                    ? "https://cdn-icons-png.flaticon.com/512/149/149071.png"
                                    : Model.PhotoUrl)"
                             class="rounded-circle mb-3"
                             style="width:160px; height:160px; object-fit:cover;" />

                        <form asp-controller="Profile"
                              asp-action="GenerateAvatar"
                              method="post"
                              class="mb-3">

                            <button type="submit" class="btn btn-dark w-100">
                                Змінити фото
                            </button>

                        </form>

                    </div>

                    <div class="col-md-8">

                        <form asp-controller="Profile"
                              asp-action="EditProfile"
                              method="post">

                            <input type="hidden" asp-for="PhotoUrl" />

                            <h5 class="fw-bold mb-4">Основна інформація</h5>

                            <div class="mb-3">
                                <label class="form-label">Ім'я</label>
                                <input class="form-control" value="@Model.Name" disabled />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Населений пункт</label>
                                <input class="form-control" asp-for="City" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Район</label>
                                <input class="form-control" asp-for="District" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Область</label>
                                <input class="form-control" asp-for="Region" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Телефон</label>
                                <input class="form-control" asp-for="Phone" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input class="form-control" asp-for="Email" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Про себе</label>
                                <textarea class="form-control" asp-for="About" rows="6"></textarea>
                            </div>

                            <div class="d-flex gap-2">

                                <button type="submit" class="btn btn-dark px-4">
                                    Зберегти
                                </button>

                                <a asp-controller="Profile"
                                   asp-action="MyProfile"
                                   class="btn btn-outline-dark px-4">
                                    Скасувати
                                </a>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>