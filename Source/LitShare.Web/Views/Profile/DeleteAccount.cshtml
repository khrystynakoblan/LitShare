@{
    ViewData["Title"] = "Видалення акаунту";
}

<div class="container mt-5">
    <div class="border rounded p-4 mx-auto text-center" style="max-width: 500px;">

        <h3 class="text-danger fw-bold mb-3">
            Ви впевнені, що хочете видалити акаунт?
        </h3>

        <p class="text-muted mb-4">
            Цю дію неможливо скасувати.
        </p>

        <form asp-action="DeleteAccountConfirmed" method="post">
            <button type="submit" class="btn btn-danger px-4">
                Видалити акаунт
            </button>

            <a asp-action="MyProfile" class="btn btn-outline-secondary px-4 ms-2">
                Скасувати
            </a>
        </form>

    </div>
</div>