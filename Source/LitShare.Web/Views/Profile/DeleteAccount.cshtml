@{
    ViewData["Title"] = "Видалення акаунту";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card p-5 text-center">
                <i class="bi bi-exclamation-octagon text-danger display-1 mb-4"></i>
                
                <h3 class="fw-bold text-dark mb-3">
                    Ви впевнені, що хочете видалити акаунт?
                </h3>

                <p class="text-muted mb-4">
                    Це призведе до безповоротної втрати ваших оголошень, запитів та налаштувань. Цю дію <strong>неможливо скасувати</strong>.
                </p>

                <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                    <form asp-action="DeleteAccountConfirmed" method="post" class="w-100">
                        <button type="submit" class="btn btn-dark w-100">
                            Так, видалити
                        </button>
                    </form>

                    <a asp-action="Index" class="btn btn-outline-dark w-100">
                        Скасувати
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>