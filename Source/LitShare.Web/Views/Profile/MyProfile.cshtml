@model LitShare.Web.Models.ProfileViewModel

@{
    ViewData["Title"] = "Мій профіль";
}

<div class="container mt-4" style="max-width: 1000px;">

    <div class="border rounded p-3">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
            <h4 class="m-0 fw-bold">LitShare</h4>
        </div>

        <div class="row g-3">

            <!-- LEFT -->
            <div class="col-md-4">

                <div class="border rounded p-3 text-center">
                    <img src="@(string.IsNullOrEmpty(Model.PhotoUrl) 
                            ? "https://cdn-icons-png.flaticon.com/512/149/149071.png" 
                            : Model.PhotoUrl)"
                        alt="Фото профілю"
                        class="rounded-circle mb-2"
                        style="width:120px; height:120px; object-fit:cover;" />

                    <h5 class="fw-bold">@Model.Name</h5>
                </div>

                <div class="mt-3 d-grid gap-2">
                    <a asp-controller="Profile" asp-action="AddBook" class="btn btn-dark">
                        Додати книгу
                    </a>

                    <a asp-controller="Profile" asp-action="MyBooks" class="btn btn-dark">
                        Мої книги
                    </a>

                    <a asp-controller="Profile" asp-action="EditProfile" class="btn btn-dark">
                        Редагувати профіль
                    </a>

                    <a asp-controller="Profile" asp-action="DeleteAccount" class="btn btn-outline-danger">
                        Видалити акаунт
                    </a>
                </div>

            </div>

            <!-- RIGHT -->
            <div class="col-md-8">

                <div class="border rounded p-3 mb-3">
                    <h5 class="text-center fw-bold mb-3">Основна інформація</h5>

                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Ім'я:</strong> @Model.Name</p>
                            <p><strong>Контактні дані:</strong><br />@Model.Email</p>
                            <p><strong>Email:</strong> @Model.Email</p>
                        </div>

                        <div class="col-md-6">
                            <p><strong>Область:</strong> @Model.Region</p>
                            <p><strong>Район:</strong> @Model.District</p>
                            <p><strong>Місто:</strong> @Model.City</p>
                        </div>
                    </div>
                </div>

                <div class="border rounded p-3">
                    <h5 class="text-center fw-bold mb-3">Про себе</h5>
                    <p>@Model.About</p>
                </div>

            </div>

        </div>
    </div>
</div>