@model LitShare.Web.Models.ProfileViewModel
@{
    ViewData["Title"] = "Мій профіль";
}

<div class="container mt-4 mb-5">
    <div class="row g-4 align-items-start">

        <div class="col-md-4 col-lg-3">

            <div class="card p-4 text-center border-0 shadow-sm mb-3 rounded-4">
                <img src="@(string.IsNullOrEmpty(Model.PhotoUrl) ? "https://cdn-icons-png.flaticon.com/512/149/149071.png" : Model.PhotoUrl)"
                     alt="Фото профілю"
                     class="rounded-circle shadow-sm object-fit-cover mx-auto mb-3"
                     style="width:120px; height:120px; border: 4px solid #fff;" />
                <h5 class="fw-bold mb-0">@Model.Name</h5>
                <p class="text-muted small mb-0">@Model.Email</p>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="list-group list-group-flush">
                    <a asp-controller="Post" asp-action="CreatePost"
                       class="list-group-item list-group-item-action border-0 py-3">
                        <i class="bi bi-plus-circle me-2 text-primary"></i>Додати книгу
                    </a>
                    <a asp-controller="Profile" asp-action="MyBooks"
                       class="list-group-item list-group-item-action border-0 py-3">
                        <i class="bi bi-journal-text me-2"></i>Мої книги
                    </a>
                    <a asp-controller="Favorite" asp-action="Index"
                       class="list-group-item list-group-item-action border-0 py-3">
                        <i class="bi bi-heart me-2 text-danger"></i>Вподобані
                    </a>

                    <div class="bg-light py-2 px-3 small fw-bold text-uppercase text-muted" style="font-size:0.7rem;">
                        Запити
                    </div>
                    <a asp-controller="Exchange" asp-action="ReceivedRequests"
                       class="list-group-item list-group-item-action border-0 py-3">
                        <i class="bi bi-box-arrow-in-down me-2"></i>Отримані
                    </a>
                    <a asp-controller="Exchange" asp-action="SentRequests"
                       class="list-group-item list-group-item-action border-0 py-3">
                        <i class="bi bi-send me-2"></i>Надіслані
                    </a>

                    <div class="bg-light py-2 px-3 small fw-bold text-uppercase text-muted" style="font-size:0.7rem;">
                        Налаштування
                    </div>
                    <a asp-controller="Profile" asp-action="EditProfile"
                       class="list-group-item list-group-item-action border-0 py-3">
                        <i class="bi bi-gear me-2"></i>Редагувати профіль
                    </a>
                    <a asp-controller="Profile" asp-action="DeleteAccount"
                       class="list-group-item list-group-item-action border-0 py-3 text-danger">
                        <i class="bi bi-trash me-2"></i>Видалити акаунт
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-8 col-lg-9 d-flex flex-column gap-3">

            <div class="card p-4 border-0 shadow-sm rounded-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Контактні дані</h5>
                    <a asp-action="EditProfile" class="btn btn-sm btn-outline-dark">
                        <i class="bi bi-pencil me-1"></i>Змінити
                    </a>
                </div>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="p-3 bg-light rounded-3">
                            <label class="text-muted small text-uppercase fw-bold d-block mb-1">Телефон</label>
                            <p class="fs-6 mb-0 fw-semibold">
                                @(string.IsNullOrEmpty(Model.Phone) || Model.Phone == "Номер не вказано"
                                    ? "Не вказано"
                                    : Model.Phone)
                            </p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="p-3 bg-light rounded-3">
                            <label class="text-muted small text-uppercase fw-bold d-block mb-1">Локація</label>
                            <p class="fs-6 mb-0 fw-semibold">
                                @(string.IsNullOrWhiteSpace(Model.City) ? "Не вказано" : $"{Model.City}, {Model.Region}")
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card p-4 border-0 shadow-sm rounded-4">
                <h5 class="fw-bold mb-3">Про себе</h5>
                <p class="text-secondary mb-0" style="white-space: pre-line; line-height: 1.7;">
                    @(string.IsNullOrEmpty(Model.About)
                        ? "Ви ще не додали опис профілю. Розкажіть про ваші літературні смаки!"
                        : Model.About)
                </p>
            </div>

        </div>
    </div>
</div>
