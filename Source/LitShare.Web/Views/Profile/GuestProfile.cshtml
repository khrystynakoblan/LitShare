@model LitShare.Web.Models.ProfileViewModel
@{
    ViewData["Title"] = "Профіль користувача";
}

<div class="container mt-4">
    @* Основна інформація профілю *@
    <div class="card p-0 overflow-hidden mb-4">
        <div class="row g-0">
            <div class="col-md-4 text-center bg-light p-4 d-flex flex-column align-items-center justify-content-center border-end">
                <img src="@(string.IsNullOrEmpty(Model.PhotoUrl) ? "https://cdn-icons-png.flaticon.com/512/149/149071.png" : Model.PhotoUrl)"
                     class="rounded-circle mb-3 shadow-sm object-fit-cover bg-white"
                     style="width:160px; height:160px; border: 4px solid white;" 
                     alt="@Model.Name" />
                <h3 class="fw-bold text-dark mb-0">@Model.Name</h3>
                <div class="mt-3">
                    <a asp-controller="Review" asp-action="Index" asp-route-userId="@Model.UserId" class="btn btn-sm btn-dark px-3">
                        Відгуки (@Model.ReviewCount)
                    </a>
                </div>
            </div>
            
            <div class="col-md-8 p-4">
                <h5 class="fw-bold mb-4">Контактна інформація</h5>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="text-muted small text-uppercase fw-bold d-block">Email</label>
                        <p class="text-dark">@Model.Email</p>

                        <label class="text-muted small text-uppercase fw-bold d-block mt-3">Телефон</label>
                        @if (Model.Phone != "Номер не вказано")
                        {
                            <p class="fw-bold">
                                <a href="tel:@Model.Phone" class="text-decoration-none text-dark">@Model.Phone</a>
                            </p>
                        }
                        else
                        {
                            <p class="text-muted">Не вказано</p>
                        }
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small text-uppercase fw-bold d-block">Локація</label>
                        <p class="mb-1"><strong>Область:</strong> @(Model.Region ?? "—")</p>
                        <p class="mb-1"><strong>Район:</strong> @(Model.District ?? "—")</p>
                        <p class="mb-0"><strong>Місто:</strong> @(Model.City ?? "—")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Про себе *@
    <div class="card p-4 mb-5">
        <h5 class="fw-bold mb-3">Про себе</h5>
        <p class="text-secondary mb-0" style="white-space: pre-line;">
            @(string.IsNullOrEmpty(Model.About) ? "Користувач не залишив опису." : Model.About)
        </p>
    </div>

    @* Книги користувача *@
    <div class="mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold mb-0">Книги користувача</h4>
            <span class="badge bg-light text-dark border px-3">@(Model.UserBooks?.Count() ?? 0) оголошень</span>
        </div>

        @if (Model.UserBooks != null && Model.UserBooks.Any())
        {
            <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-4">
                @foreach (var book in Model.UserBooks)
                {
                    <div class="col">
                        <div class="card h-100 p-2">
                            <a asp-controller="Post" asp-action="Details" asp-route-id="@book.Id" class="text-decoration-none text-dark h-100 d-flex flex-column">
                                <div class="bg-light rounded overflow-hidden" style="aspect-ratio: 3/4;">
                                    @if (!string.IsNullOrEmpty(book.PhotoUrl))
                                    {
                                        <img src="@book.PhotoUrl" class="w-100 h-100 object-fit-cover" alt="@book.Title" />
                                    }
                                    else
                                    {
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                                            <i class="bi bi-book text-muted display-6"></i>
                                        </div>
                                    }
                                </div>
                                <div class="card-body px-1 py-2 text-center mt-auto">
                                    <p class="mb-0 fw-bold small text-truncate" title="@book.Title">@book.Title</p>
                                    <p class="mb-1 text-muted small text-truncate">@book.Author</p>
                                    @if (!string.IsNullOrEmpty(book.City))
                                    {
                                        <p class="mb-0 text-muted extra-small">
                                            <i class="bi bi-geo-alt"></i> @book.City
                                        </p>
                                    }
                                </div>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card text-center py-5 border-0 bg-light">
                <i class="bi bi-journal-x display-1 text-muted mb-3"></i>
                <p class="text-muted fs-5">Цей користувач ще не додав жодної книги.</p>
            </div>
        }
    </div>
</div>