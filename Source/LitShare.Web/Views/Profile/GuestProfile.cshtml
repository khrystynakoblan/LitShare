@model LitShare.Web.Models.ProfileViewModel

@{
    ViewData["Title"] = "Профіль користувача";
}

<div class="container mt-4">
    <div class="border rounded p-0 overflow-hidden shadow-sm">
        <div class="row g-0">
            <div class="col-md-4 border-end p-4 text-center bg-light">
                <img src="@(string.IsNullOrEmpty(Model.PhotoUrl) ? "https://cdn-icons-png.flaticon.com/512/149/149071.png" : Model.PhotoUrl)"
                     class="rounded-circle mb-3 shadow-sm"
                     style="width:160px; height:160px; object-fit:cover; border: 4px solid white;" />
                <h4 class="fw-bold">@Model.Name</h4>
            </div>

            <div class="col-md-8 p-4 bg-white">
                <h5 class="fw-bold mb-4 text-center text-md-start">Основна інформація:</h5>
                <div class="row">
                    <div class="col-sm-6">
                        <p class="mb-1 text-muted small text-uppercase">Ім'я:</p>
                        <p class="fw-bold">@Model.Name</p>
                        <p class="mb-1 text-muted small text-uppercase mt-3">Email:</p>
                        <p>@Model.Email</p>

                     <p class="mb-1 text-muted small text-uppercase mt-3">Контактні дані:</p>
                    @if (Model.Phone != "Номер не вказано")
                    {
                            <p class="fw-bold">
                                <a href="tel:@Model.Phone" class="text-decoration-none text-dark"> @Model.Phone
                                </a>
                            </p>
                    }
                    else
                    {
                            <p class="text-muted small">@Model.Phone</p>
                    }
                    </div>
                    <div class="col-sm-6">
                        <p class="mb-1 text-muted small text-uppercase">Область:</p>
                        <p>@Model.Region</p>
                        <p class="mb-1 text-muted small text-uppercase">Район:</p>
                        <p>@Model.District</p>
                        <p class="mb-1 text-muted small text-uppercase">Місто:</p>
                        <p>@Model.City</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="border rounded p-4 mt-4 bg-white shadow-sm">
        <h5 class="fw-bold mb-3">Про себе:</h5>
        <p class="text-muted">@(string.IsNullOrEmpty(Model.About) ? "Користувач не залишив опису." : Model.About)</p>
    </div>

    <div class="mt-5">
        <h5 class="fw-bold mb-4">Книги користувача:</h5>
        <div class="row row-cols-2 row-cols-md-5 g-4">
            @if (Model.UserBooks != null && Model.UserBooks.Any())
            {
                @foreach (var book in Model.UserBooks)
                {
                            <div class="col text-center">
                                <div class="card h-100 border-0 shadow-sm">
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center overflow-hidden" style="aspect-ratio: 3/4;">
                                @if (!string.IsNullOrEmpty(book.PhotoUrl))
                                {
                                                <img src="@book.PhotoUrl" class="w-100 h-100" style="object-fit: cover;" alt="@book.Title" />
                                }
                                else
                                {
                                                <i class="bi bi-book text-muted fs-1"></i>
                                }
                                    </div>
                                    <div class="card-body px-0 py-2">
                                        <p class="mb-0 fw-bold small text-truncate" title="@book.Title">@book.Title</p>
                                        <p class="mb-0 text-muted extra-small">@book.Author</p>
                                @if (!string.IsNullOrEmpty(book.City))
                                {
                                                <p class="mb-0 text-muted extra-small"><i class="bi bi-geo-alt"></i> @book.City</p>
                                }
                                    </div>
                                </div>
                            </div>
                }
            }
            else
            {
                    <div class="col-12 text-center py-5">
                        <p class="text-muted">Цей користувач ще не додав жодної книги.</p>
                    </div>
            }
        </div>
    </div>
</div>

<style>
    .extra-small { font-size: 0.75rem; }
</style>