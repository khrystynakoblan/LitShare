@model LitShare.Web.Models.ProfileViewModel

@{
    ViewData["Title"] = "Профіль користувача";
}

<div class="container mt-4">

    <div class="card shadow-sm overflow-hidden">

        <div class="row g-0">

            <div class="col-md-4 text-center bg-light p-4 border-end">

                <img src="@(string.IsNullOrEmpty(Model.PhotoUrl)
                            ? "https://cdn-icons-png.flaticon.com/512/149/149071.png"
                            : Model.PhotoUrl)"
                     class="rounded-circle mb-3 shadow-sm"
                     style="width:160px; height:160px; object-fit:cover; border:4px solid #fff;" />

                <h4 class="fw-bold">
                    @Model.Name
                </h4>

            </div>

            <div class="col-md-8 p-4">

                <h5 class="fw-bold mb-4">Основна інформація</h5>

                <div class="row">

                    <div class="col-sm-6">

                        <p class="text-muted small mb-1">Ім'я</p>
                        <p class="fw-bold">@Model.Name</p>

                        <p class="text-muted small mb-1 mt-3">Email</p>
                        <p>@Model.Email</p>

                        <p class="text-muted small mb-1 mt-3">Контакти</p>

                        @if (!string.IsNullOrEmpty(Model.Phone))
                        {
                            <a href="tel:@Model.Phone"
                               class="text-dark text-decoration-none fw-bold">
                                @Model.Phone
                            </a>
                        }
                        else
                        {
                            <p class="text-muted">Не вказано</p>
                        }

                    </div>

                    <div class="col-sm-6">

                        <p class="text-muted small mb-1">Область</p>
                        <p>@Model.Region</p>

                        <p class="text-muted small mb-1">Район</p>
                        <p>@Model.District</p>

                        <p class="text-muted small mb-1">Місто</p>
                        <p>@Model.City</p>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="card shadow-sm p-4 mt-4">

        <h5 class="fw-bold mb-3">Про себе</h5>

        <p class="text-muted mb-0">
            @(string.IsNullOrEmpty(Model.About)
                ? "Користувач не залишив опису."
                : Model.About)
        </p>

    </div>

    <div class="text-center mt-3">

        <a asp-controller="Review"
           asp-action="Index"
           asp-route-userId="@Model.UserId"
           class="btn btn-dark px-4">

            Переглянути відгуки (@Model.ReviewCount)

        </a>

    </div>

    <div class="mt-5">

        <h5 class="fw-bold mb-4">
            Книги користувача
        </h5>

        <div class="row row-cols-2 row-cols-md-5 g-4">

            @if (Model.UserBooks?.Any() == true)
            {
                @foreach (var book in Model.UserBooks)
                {
                    <div class="col">

                        <a asp-controller="Post"
                           asp-action="Details"
                           asp-route-id="@book.Id"
                           class="text-decoration-none text-dark">

                            <div class="card h-100 shadow-sm border-0">

                                <div class="bg-light d-flex align-items-center justify-content-center"
                                     style="aspect-ratio:3/4; overflow:hidden;">

                                    @if (!string.IsNullOrEmpty(book.PhotoUrl))
                                    {
                                        <img src="@book.PhotoUrl"
                                             class="w-100 h-100"
                                             style="object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-book fs-1 text-muted"></i>
                                    }

                                </div>

                                <div class="card-body text-center p-2">

                                    <p class="fw-bold small text-truncate mb-0"
                                       title="@book.Title">
                                        @book.Title
                                    </p>

                                    <p class="text-muted small mb-0">
                                        @book.Author
                                    </p>

                                    @if (!string.IsNullOrEmpty(book.City))
                                    {
                                        <p class="text-muted small mb-0">
                                            <i class="bi bi-geo-alt"></i>
                                            @book.City
                                        </p>
                                    }

                                </div>

                            </div>

                        </a>

                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted mb-0">
                        Цей користувач ще не додав жодної книги.
                    </p>
                </div>
            }

        </div>

    </div>

</div>