@model LitShare.Web.Models.EditReviewViewModel

@{
    ViewData["Title"] = "Редагувати відгук";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-sm p-4">

                <h4 class="fw-bold text-center mb-4">
                    Редагувати відгук
                </h4>

                <form asp-action="Edit" method="post">

                    <input type="hidden" asp-for="ReviewId" />
                    <input type="hidden" asp-for="ReviewedUserId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <p class="fw-bold mb-2">Оцінка</p>

                    <div class="d-flex gap-2 mb-3" id="star-rating">

                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="bi @(i <= Model.Rating ? "bi-star-fill" : "bi-star") fs-3 text-warning star-btn"
                               data-value="@i"></i>
                        }

                    </div>

                    <input type="hidden"
                           asp-for="Rating"
                           id="ratingInput" />

                    <span asp-validation-for="Rating" class="text-danger"></span>

                    <div class="mb-4 mt-3">

                        <label class="fw-bold mb-2">
                            Коментар (необов'язково)
                        </label>

                        <textarea asp-for="Text"
                                  class="form-control"
                                  rows="5"
                                  placeholder="Ваш коментар..."></textarea>

                        <span asp-validation-for="Text" class="text-danger"></span>

                    </div>

                    <button type="submit" class="btn btn-dark w-100 py-2">
                        Зберегти зміни
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/reviews.js"></script>
}