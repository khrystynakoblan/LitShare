@model LitShare.Web.Models.EditReviewViewModel
@{
    ViewData["Title"] = "Редагувати відгук";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card p-4 p-md-5 shadow-sm border-0">
                <h4 class="fw-bold text-center mb-4">@ViewData["Title"]</h4>

                <form asp-action="Edit" method="post" id="editReviewForm">
                    <input type="hidden" asp-for="ReviewId" />
                    <input type="hidden" asp-for="ReviewedUserId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                    <div class="text-center mb-4">
                        <label class="fw-bold d-block mb-2">Ваша оцінка</label>
                        <div class="d-flex justify-content-center gap-2" id="star-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= Model.Rating ? "bi-star-fill" : "bi-star") fs-1 text-warning star-btn" 
                                   style="cursor:pointer;" data-value="@i"></i>
                            }
                        </div>
                        <input type="hidden" asp-for="Rating" id="ratingInput" />
                        <span asp-validation-for="Rating" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="fw-bold mb-2" asp-for="Text">Коментар</label>
                        <textarea asp-for="Text" class="form-control" rows="5" placeholder="Ваш відгук про користувача..."></textarea>
                        <span asp-validation-for="Text" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-dark py-2 fw-bold">Зберегти зміни</button>
                        <a asp-controller="Review" asp-action="Index" asp-route-userId="@Model.ReviewedUserId" class="btn btn-outline-dark py-2">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const stars = document.querySelectorAll('.star-btn');
            const ratingInput = document.getElementById('ratingInput');

            function updateStars(value) {
                stars.forEach((s, i) => {
                    if (i < value) {
                        s.classList.replace('bi-star', 'bi-star-fill');
                    } else {
                        s.classList.replace('bi-star-fill', 'bi-star');
                    }
                });
            }

            stars.forEach(star => {
                star.addEventListener('click', () => {
                    const value = parseInt(star.getAttribute('data-value'));
                    ratingInput.value = value;
                    updateStars(value);
                });

                star.addEventListener('mouseover', () => {
                    const value = parseInt(star.getAttribute('data-value'));
                    updateStars(value);
                });

                star.addEventListener('mouseout', () => {
                    const current = parseInt(ratingInput.value) || 0;
                    updateStars(current);
                });
            });
        });
    </script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}