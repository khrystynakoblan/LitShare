@model LitShare.Web.Models.ReviewListViewModel
@{
    ViewData["Title"] = "Відгуки";
}

<div class="container mt-4 mb-5" style="max-width: 850px;">
    @if (Context.Request.Query.ContainsKey("success"))
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 rounded-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill fs-4 me-3"></i>
                <div><strong>Успішно!</strong> Ваш відгук було збережено.</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0 text-dark">Відгуки про @Model.ReviewedUserName</h3>
        </div>
        <a asp-controller="Profile" asp-action="GuestProfile" asp-route-id="@Model.ReviewedUserId" class="btn btn-outline-dark btn-sm rounded-pill px-3">
            <i class="bi bi-arrow-left me-1"></i> До профілю
        </a>
    </div>

    <div class="card p-4 mb-5 border-0 shadow-sm rounded-4 text-center bg-white">
        <div class="row align-items-center g-0">
            <div class="col-md-6 border-md-end py-2">
                <h1 class="display-2 fw-bold mb-0 text-dark">@Model.AverageRating.ToString("0.0")</h1>
                <div class="mb-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Floor(Model.AverageRating))
                        {
                            <i class="bi bi-star-fill text-warning fs-3"></i>
                        }
                        else if (i == Math.Ceiling(Model.AverageRating) && Model.AverageRating % 1 >= 0.3)
                        {
                            <i class="bi bi-star-half text-warning fs-3"></i>
                        }
                        else
                        {
                            <i class="bi bi-star text-warning fs-3"></i>
                        }
                    }
                </div>
                <p class="text-muted small mb-0">На основі @Model.TotalReviews відгуків</p>
            </div>
            <div class="col-md-6 py-2 px-md-4">
                @if (Model.CanLeaveReview)
                {
                    <h6 class="fw-bold mb-2">Залиште свій відгук</h6>
                    <p class="text-muted small mb-3">Ваш досвід допоможе іншим учасникам спільноти.</p>
                    <a asp-action="Create" asp-route-userId="@Model.ReviewedUserId" class="btn btn-dark rounded-pill px-4 shadow-sm">
                        Написати відгук
                    </a>
                }
                else
                {
                    <i class="bi bi-shield-check text-success fs-1 mb-2 d-block"></i>
                    <p class="text-muted small mb-0 px-3">Тут зібрані чесні враження спільноти про взаємодію з користувачем.</p>
                }
            </div>
        </div>
    </div>

    @if (Model.CurrentUserReview != null)
    {
        <div class="mb-5">
            <div class="d-flex align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-person-badge me-2 text-primary"></i>Ваш відгук</h5>
                <span class="badge bg-dark ms-2 rounded-pill px-3">Ви</span>
            </div>
            <div class="card p-4 border-0 shadow-sm rounded-4" style="background: #fdfdfd; border-left: 5px solid #212529 !important;">
                <div class="d-flex align-items-center mb-3">
                    <img src="@(string.IsNullOrEmpty(Model.CurrentUserReview.ReviewerPhotoUrl) ? "https://cdn-icons-png.flaticon.com/512/149/149071.png" : Model.CurrentUserReview.ReviewerPhotoUrl)" 
                         class="rounded-circle shadow-sm me-3 border border-2 border-white" style="width:52px; height:52px; object-fit:cover;" />
                    <div>
                        <span class="fw-bold d-block text-dark">@Model.CurrentUserReview.ReviewerName</span>
                        <span class="text-muted extra-small">@Model.CurrentUserReview.Date.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="ms-auto bg-white shadow-sm px-3 py-1 rounded-pill">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="bi @(i <= Model.CurrentUserReview.Rating ? "bi-star-fill" : "bi-star") text-warning small"></i>
                        }
                    </div>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.CurrentUserReview.Text))
                {
                    <p class="text-dark mb-4 lead-sm" style="white-space: pre-line; font-size: 0.95rem;">@Model.CurrentUserReview.Text</p>
                }

                <div class="d-flex gap-2 border-top pt-3">
                    <a asp-action="Edit" asp-route-reviewId="@Model.CurrentUserReview.Id" class="btn btn-light btn-sm rounded-pill px-3 border">
                        <i class="bi bi-pencil me-1"></i> Редагувати
                    </a>
                    <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#deleteReviewModal">
                        <i class="bi bi-trash me-1"></i> Видалити
                    </button>
                </div>
            </div>
        </div>

        <div class="modal fade" id="deleteReviewModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow rounded-4">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold">Видалення відгуку</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body py-4">
                        Ви впевнені, що хочете безповоротно видалити свій відгук? Цю дію неможливо скасувати.
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Скасувати</button>
                        <form asp-action="Delete" method="post">
                            <input type="hidden" name="reviewId" value="@Model.CurrentUserReview.Id" />
                            <input type="hidden" name="reviewedUserId" value="@Model.ReviewedUserId" />
                            <button type="submit" class="btn btn-danger rounded-pill px-4">Так, видалити</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <h5 class="fw-bold mb-4 mt-2">
        <i class="bi bi-chat-left-dots me-2 text-muted"></i>
        @(Model.CurrentUserReview != null ? "Інші відгуки" : "Всі відгуки")
    </h5>

    @if (!Model.Reviews.Any())
    {
        <div class="card p-5 text-center bg-white border-0 shadow-sm rounded-4">
            <div class="card-body">
                <i class="bi bi-chat-square-text display-3 text-light mb-3 d-block"></i>
                <p class="text-muted fs-5">Поки що немає відгуків від інших користувачів.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var review in Model.Reviews)
            {
                <div class="col-12">
                    <div class="card p-3 border-0 shadow-sm rounded-4 card-hover">
                        <div class="d-flex align-items-center mb-3">
                            <a asp-controller="Profile" asp-action="GuestProfile" asp-route-id="@review.ReviewerId" class="text-decoration-none text-dark d-flex align-items-center">
                                <img src="@(string.IsNullOrEmpty(review.ReviewerPhotoUrl) ? "https://cdn-icons-png.flaticon.com/512/149/149071.png" : review.ReviewerPhotoUrl)" 
                                     class="rounded-circle me-3 object-fit-cover shadow-xs" style="width:40px; height:40px; border: 1px solid #eee;" />
                                <span class="fw-bold small">@review.ReviewerName</span>
                            </a>
                            <span class="ms-auto text-muted extra-small">@review.Date.ToString("dd.MM.yyyy")</span>
                        </div>
                        
                        <div class="mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star") text-warning small"></i>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(review.Text))
                        {
                            <p class="mb-0 text-secondary small lh-base" style="white-space: pre-line;">@review.Text</p>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .border-md-end {
        border-right: 1px solid #f0f0f0;
    }
    @@media (max-width: 767.98px) {
        .border-md-end {
            border-right: none;
            border-bottom: 1px solid #f0f0f0;
            padding-bottom: 1.5rem;
            margin-bottom: 1.5rem;
        }
    }
</style>