@model IEnumerable<LitShare.BLL.DTOs.SentRequestDto>

@{
    ViewData["Title"] = "Мої запити";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Надіслані запити на обмін</h2>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0 text-center p-5">
            <p class="text-muted mb-0 fs-5">Ви ще не надсилали жодного запиту.</p>
            <div class="mt-3">
                <a href="/" class="btn btn-dark">Шукати книги</a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table admin-table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4">Книга</th>
                            <th>Автор</th>
                            <th>Дата запиту</th>
                            <th>Статус</th>
                            <th class="text-end pe-4">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold text-dark">@request.BookTitle</span>
                                </td>
                                <td>@request.BookAuthor</td>
                                <td>@request.CreatedAt.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @{
                                        var badgeClass = request.Status switch
                                        {
                                            "Pending" or "Очікує" => "bg-warning text-dark",
                                            "Accepted" or "Прийнято" => "badge-user",
                                            "Rejected" or "Відхилено" => "badge-admin",
                                            "Завершено" => "bg-secondary text-white",
                                            _ => "bg-info text-white"
                                        };
                                        var statusUkr = request.Status switch
                                        {
                                            "Pending" => "Очікує",
                                            "Accepted" => "Прийнято",
                                            "Rejected" => "Відхилено",
                                            _ => request.Status
                                        };
                                    }
                                    <span class="badge @badgeClass px-3 py-2" style="border-radius: 20px;">@statusUkr</span>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-controller="Post"
                                       asp-action="Details"
                                       asp-route-id="@request.PostId"
                                       class="btn btn-sm btn-outline-dark">
                                        Деталі
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>