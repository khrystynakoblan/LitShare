@model IEnumerable<LitShare.BLL.DTOs.SentRequestDto>

@{
    ViewData["Title"] = "Мої запити";
}

<div class="container mt-4">

    <h2 class="fw-bold mb-4">Надіслані запити</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">

            <h5 class="text-muted">
                Ви ще не надсилали жодного запиту
            </h5>

            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-outline-dark mt-3">
                Шукати книги
            </a>

        </div>
    }
    else
    {
        <div class="card shadow-sm">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>Книга</th>
                            <th>Автор</th>
                            <th>Дата</th>
                            <th>Статус</th>
                            <th class="text-end">Дії</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var request in Model)
                        {
                            <tr>

                                <td>
                                    <strong>@request.BookTitle</strong>
                                </td>

                                <td>
                                    @request.BookAuthor
                                </td>

                                <td>
                                    @request.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </td>

                                <td>

                                    @{
                                        var statusText = request.Status switch
                                        {
                                            "Pending" => "Очікує",
                                            "Accepted" => "Прийнято",
                                            "Rejected" => "Відхилено",
                                            _ => request.Status
                                        };

                                        var badgeClass = request.Status switch
                                        {
                                            "Pending" => "bg-warning text-dark",
                                            "Accepted" => "bg-success",
                                            "Rejected" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }

                                    <span class="badge @badgeClass">
                                        @statusText
                                    </span>

                                </td>

                                <td class="text-end">

                                    <a asp-controller="Post"
                                       asp-action="Details"
                                       asp-route-id="@request.PostId"
                                       class="btn btn-sm btn-outline-dark">
                                        Деталі
                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    }

</div>