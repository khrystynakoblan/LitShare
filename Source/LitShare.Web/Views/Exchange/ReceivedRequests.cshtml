@model List<LitShare.BLL.DTOs.ReceivedRequestDto>

@{
    ViewData["Title"] = "Отримані запити";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Отримані запити</h2>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0 text-center p-5 mt-5">
            <h4 class="text-muted mt-3">У вас поки немає отриманих запитів</h4>
            <p class="text-secondary">Коли хтось надішле вам запит — він з’явиться тут</p>
            <div class="mt-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-dark">
                    Перейти до оголошень
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table admin-table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4">Книга</th>
                            <th>Від кого</th>
                            <th>Статус</th>
                            <th class="text-end pe-4">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold text-dark">@request.PostTitle</span>
                                </td>
                                <td>@request.SenderName</td>
                                <td>
                                    @{
                                        var badgeClass = request.Status switch
                                        {
                                            "Очікує" => "bg-warning text-dark",
                                            "Прийнято" => "badge-user", // Використовуємо твій кастомний клас
                                            "Відхилено" => "badge-admin", // Твій червоний бадж
                                            "Завершено" => "bg-secondary text-white",
                                            _ => "bg-light text-dark"
                                        };
                                    }
                                    <span class="badge @badgeClass px-3 py-2" style="border-radius: 20px;">@request.Status</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-controller="Post" asp-action="Details" asp-route-id="@request.PostId" class="btn btn-sm btn-outline-dark">
                                            Деталі
                                        </a>
                                        
                                        @if (request.Status == "Очікує")
                                        {
                                            <form asp-action="AcceptRequest" method="post" class="d-inline">
                                                <input type="hidden" name="requestId" value="@request.Id" />
                                                <button type="submit" class="btn btn-sm btn-dark">Прийняти</button>
                                            </form>
                                            <form asp-action="RejectRequest" method="post" class="d-inline">
                                                <input type="hidden" name="requestId" value="@request.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Відхилити</button>
                                            </form>
                                        }

                                        @if (request.Status == "Прийнято")
                                        {
                                            <form asp-action="CompleteDeal" method="post" class="d-inline">
                                                <input type="hidden" name="requestId" value="@request.Id" />
                                                <button type="submit" class="btn btn-sm btn-dark">Завершити</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>