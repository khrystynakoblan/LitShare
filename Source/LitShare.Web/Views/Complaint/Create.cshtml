@model LitShare.Web.Models.ComplaintViewModel
@{
    ViewData["Title"] = "Звіт про проблему";
    var complaintOptions = new[]
    {
        "Неправдива інформація в оголошенні",
        "Неприпустимий контент або спам",
        "Проблеми з обміном",
        "Інше",
    };
}

<div class="container mt-5 d-flex justify-content-center">
    <div class="card col-md-6 col-lg-5 p-5">
        <h4 class="fw-bold text-center mb-4">@ViewData["Title"]</h4>

        <form asp-action="Create" method="post" class="needs-validation">
            <input type="hidden" asp-for="PostId" />
            <p class="fw-bold mb-3">Оберіть проблему:</p>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <span asp-validation-for="ComplaintType" class="text-danger d-block mb-2"></span>

            @foreach (var option in complaintOptions)
            {
                <div class="form-check mb-3">
                    <input class="form-check-input complaint-radio" type="radio" asp-for="ComplaintType" value="@option" id="type_@option.GetHashCode()" required />
                    <label class="form-check-label" for="type_@option.GetHashCode()">
                        @option
                    </label>
                </div>
            }

            <div class="mb-4">
                <textarea asp-for="AdditionalText" id="AdditionalText" class="form-control" rows="7"
                          placeholder="Опишіть проблему (доступно при виборі 'Інше')"></textarea>
                <span asp-validation-for="AdditionalText" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between gap-3 mt-4">
                <a asp-controller="Post" asp-action="Details" asp-route-id="@Model.PostId" class="btn btn-outline-dark w-100">
                    Скасувати
                </a>
                <button type="submit" class="btn btn-dark w-100">
                    Надіслати
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/complaints.js" asp-append-version="true"></script>
}